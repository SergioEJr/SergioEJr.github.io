---
// HeroSim — active-matter "color-reveal" name hero.
//
// A live Active Brownian Particle (ABP) gas drifts across a <canvas> and passes
// FREELY through the name's letters — the glyphs exert no force. The trick: a
// particle is recolored to the heading accent color while it is inside a glyph,
// so the moving gas spells out the name. The cursor is a repulsion well that
// pushes the gas around. (An ABP gas evokes the owner's active-matter research.)
//
// The name is rendered twice: once as a real <h1> in the DOM (accessibility +
// SEO; visually transparent) and once onto an offscreen canvas, whose alpha
// mask becomes a signed field used only to test inside/outside for recoloring.
//
// Conventions mirror the hero-tilt script that used to live in index.astro:
// prefers-reduced-motion / (hover: hover) guards, a requestAnimationFrame loop
// with a re-init-safe cleanup handle for ClientRouter navigations, and CSS vars
// read from :root so the sim follows the theme.
import { SITE_TITLE } from "../consts";

// The name renders on two lines. Each line is a wall the particles accumulate
// against; the offscreen SDF draws the same lines at the same positions so the
// particle crust lines up with the visible text.
const NAME_LINES = SITE_TITLE.toUpperCase().split(" ");
---

<div class="hero-sim" data-hero-sim>
  <!-- Background grid that fades softly into the page (extends beyond the box). -->
  <div class="hero-sim-grid" aria-hidden="true"></div>
  <canvas class="hero-sim-canvas" aria-hidden="true"></canvas>
  <!-- Real, crawlable name for accessibility/SEO. Visually invisible and inert
       (no selection / text cursor) so it doesn't break the simulation illusion;
       the accent-colored particles passing through it spell the name. -->
  <h1 class="hero-sim-name" aria-hidden="false">
    {NAME_LINES.map((line) => <span class="hero-sim-line">{line}</span>)}
  </h1>
</div>

<script>
  type Vec = { x: number; y: number };

  // Reusable per-mount controller so ClientRouter navigations don't stack loops.
  function initHeroSim() {
    const rootEl = document.querySelector<HTMLElement>("[data-hero-sim]");
    if (!rootEl) return;

    const canvasEl =
      rootEl.querySelector<HTMLCanvasElement>(".hero-sim-canvas");
    const nameEl = rootEl.querySelector<HTMLElement>(".hero-sim-name");
    if (!canvasEl || !nameEl) return;

    // IDEMPOTENCY GUARD. initHeroSim runs twice on first load (module eval +
    // astro:page-load) on the SAME canvas element. A canvas can hold only one
    // context, and getContext() returns that same object on every call — so a
    // second init that tears down and re-acquires the live canvas's WebGL context
    // leaves it permanently lost (a blank hero). If THIS canvas is already bound,
    // do nothing. A real navigation back to home swaps in a fresh canvas element
    // (no mark), so that still re-initialises correctly.
    if ((canvasEl as any).__heroSimBound) return;
    (canvasEl as any).__heroSimBound = true;

    // Tear down any PREVIOUS instance (from a prior home visit — a different,
    // now-detached canvas element). The cleanup handle is stored on `window`
    // (not on the [data-hero-sim] element) because ClientRouter swaps in a
    // brand-new element on every navigation back to home — a handle stored on the
    // old element would be discarded with it, leaving its RAF loop + observers
    // running forever and stacking a new loop each visit (the lag regression).
    (window as any).__heroSimCleanup?.();

    // Non-null aliases so TypeScript keeps the narrowing inside the nested
    // closures below (querySelector returns nullable types).
    const root: HTMLElement = rootEl;
    const canvas: HTMLCanvasElement = canvasEl;

    // RENDER BACKEND: prefer WebGL (all particles drawn in a few GPU calls — the
    // only way to keep Firefox smooth at the SAME density as Chrome, since
    // Canvas2D's per-particle draw-call overhead is what crawls there). A visible
    // canvas can hold only ONE context type, so we try WebGL first and fall back
    // to Canvas2D only if it's unavailable/blocklisted. The Canvas2D path then
    // renders a single STATIC frame (no 60k-call animation) — the right tradeoff,
    // since browsers lacking WebGL are the low-power devices that would choke on
    // the Canvas2D animation anyway. The offscreen field/sprite builders use their
    // OWN 2d canvases, unaffected by this choice.
    // PROBE WebGL on a throwaway canvas first (a real context can only be taken
    // once per canvas, and we must not "use up" the visible canvas on WebGL if it
    // can't actually compile our shader — we'd be unable to fall back to 2D). The
    // probe checks both context creation AND a trivial shader compile.
    const webglSupported = (() => {
      try {
        const t = document.createElement("canvas");
        const g = (t.getContext("webgl") ||
          t.getContext("experimental-webgl")) as WebGLRenderingContext | null;
        if (!g) return false;
        const sh = g.createShader(g.VERTEX_SHADER);
        if (!sh) return false;
        g.shaderSource(sh, "void main(){gl_Position=vec4(0.0);}");
        g.compileShader(sh);
        const ok = !!g.getShaderParameter(sh, g.COMPILE_STATUS);
        g.deleteShader(sh);
        return ok;
      } catch {
        return false;
      }
    })();

    let gl: WebGLRenderingContext | null = null;
    if (webglSupported) {
      try {
        gl =
          (canvas.getContext("webgl", {
            alpha: true,
            premultipliedAlpha: true,
            antialias: false,
            depth: false,
            stencil: false,
          }) as WebGLRenderingContext | null) ||
          (canvas.getContext(
            "experimental-webgl",
          ) as WebGLRenderingContext | null);
      } catch {
        gl = null;
      }
    }
    const useGL = !!gl;
    // 2D context only when WebGL is unavailable (static fallback frame).
    const ctx: CanvasRenderingContext2D | null = useGL
      ? null
      : canvas.getContext("2d", { alpha: true });
    if (!useGL && !ctx) return;

    // Each name line is rendered as its own wall (frontmatter consts aren't in
    // script scope, so read the lines from the DOM).
    const lineEls = Array.from(
      root.querySelectorAll<HTMLElement>(".hero-sim-line"),
    );

    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const canHover = window.matchMedia("(hover: hover)").matches;

    // ---- Tunables -------------------------------------------------------
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0; // CSS px
    let H = 0;
    const MAX_SIM_W = 1440; // 14-inch MacBook-ish CSS viewport width
    // CONSTANT DENSITY: legibility depends on particles-per-area, not raw count.
    // We keep one particle per DENSITY px² so the gas looks identical at any
    // window size — until we hit MAX_PARTICLES (perf cap), past which big screens
    // thin out gracefully. Mobile gets a slightly denser, smaller-dot treatment
    // for legibility in the tighter viewport.
    const DENSITY = 12; // px² per particle (smaller = denser)
    const MOBILE_DENSITY = 9;
    const MAX_PARTICLES = 100000;
    const isMobileSim = () => W < 600;
    const density = () => (isMobileSim() ? MOBILE_DENSITY : DENSITY);
    const targetCount = () => {
      const area = Math.max(1, W * H);
      return Math.min(Math.round(area / density()), MAX_PARTICLES);
    };

    // ===================================================================
    // TWEAKABLE PARAMETERS — all the knobs for tuning the look live here.
    //   DENSITY ........ gas density (px² per particle; smaller = denser) [above]
    //   MAX_PARTICLES .. perf cap on particle count                      [above]
    //   DIFFUSION ...... Brownian "temperature" (px/s of random drift)
    //   DOT_R .......... particle size (px radius)
    //   GLOW ........... glow on activated (inside-letter) particles
    //   ALPHA_OUT ...... opacity of the ambient (outside) gas
    //   ALPHA_IN ....... opacity of the activated (inside-letter) particles
    //   LIGHT_GAS / DARK_GAS ... outside-gas color per theme
    //   inside color ... readColors() uses --color-accent (heading color)
    //   CURSOR_R / CURSOR_PUSH . cursor repulsion size / strength
    //   Grid look (opacity, size, bleed, fade) is in the <style> below.
    // ===================================================================
    // Pure Brownian motion (no self-propulsion / no orientation): each particle
    // gets a random kick every frame. We dropped the ABP model — the wall
    // boundary-layer phenomenon is no longer the point (letters are revealed by
    // recoloring, not accumulation), so the heading state, rotational diffusion,
    // and per-particle Math.cos/Math.sin are pure cost. Brownian motion costs one
    // table lookup per axis instead, which Firefox in particular handles far
    // better than 100k live trig calls per frame.
    const DIFFUSION = 300; // random-drift magnitude (px/s) — gas "temperature"
    const DOT_R = 1.0; // particle radius (px) — small for crisp, dense letters
    const MOBILE_DOT_R = 0.8;
    const dotRadius = () => (isMobileSim() ? MOBILE_DOT_R : DOT_R);
    // GLOW SIZE knob — the shadowBlur radius (px) baked into the name/JR sprites.
    // Larger = bigger, softer halo around the activated letters. The sprite canvas
    // auto-sizes to (dotRadius + GLOW) so the halo is never clipped.
    const GLOW = 4; // halo radius (px)
    // GLOW DENSITY knob — how many times the shadow is stacked into the sprite.
    // This controls the HALO FALLOFF near the dot, which is what makes activated
    // particles read as "fuzzy" (glow hugs the dot, opaque near the core) vs.
    // "pointy" (glow goes transparent right at the dot edge, so each particle is a
    // discernible point in faint haze). A single shadowBlur pass is already quite
    // transparent next to the core; each extra stacked fill re-adds opacity that's
    // densest near the center and thins outward, so higher values pull the near-
    // core opacity UP without spreading the outer edge — exactly the tight, opaque
    // hug of the original live drop-shadow. Measured near-core alpha (2px out):
    // stack2≈52, stack4≈93, stack6≈125. 6 restores the original fuzzy look; it
    // also keeps overlapping halos merging into one cohesive body. Tune w/ GLOW.
    const GLOW_STACK = 3;
    const ALPHA_OUT = 0.4; // ambient gas opacity (Canvas2D single-fill path)
    // WebGL draws each gas particle as a SEPARATE sprite, so overlaps ACCUMULATE
    // (unlike the 2D path's single fill). At ALPHA_OUT=0.4 dense regions saturate
    // to opaque light-gray (a white-out). A much lower per-particle alpha lets the
    // accumulation settle near the intended subtle gas tone. Tune to taste.
    const GL_ALPHA_OUT = 0.25; // ambient gas opacity (WebGL accumulating path)
    const ALPHA_IN = 1.0; // activated (name) particle opacity
    const CURSOR_R = 20; // cursor repulsion radius (px)
    const CURSOR_PUSH = 5000; // cursor repulsion strength (pushes the gas)
    // CLICK EXPLOSION — a click fires a one-shot radial impulse: particles within
    // BLAST_R get shoved outward, strongest at the center, falling off to the edge.
    // The impulse decays over BLAST_DECAY frames (then the normal DAMP settles the
    // gas back), so there's no lingering force or cleanup. MAX_SPEED is briefly
    // lifted during a blast so the explosion actually shoots rather than clamping.
    const BLAST_R = 50; // explosion radius (px)
    const BLAST_PUSH = 30000; // explosion strength (outward px/s impulse at center)
    const BLAST_DECAY = 0.9; // per-frame falloff of the blast strength (<1)
    const BLAST_SPEED = 900; // px/s clamp while a blast is active (lets it shoot)
    const DAMP = 0.9; // velocity damping per step
    const MAX_SPEED = 140; // px/s clamp
    // Outside-gas color per theme. Light mode: a mid gray (darker than before so
    // it's visible, lighter than the navy letters so the name still pops).
    const DARK_GAS = ""; // "" → use --color-text-muted
    const LIGHT_GAS = "#999999";

    // ---- State ----------------------------------------------------------
    // Particles are stored in parallel typed arrays (Structure-of-Arrays) rather
    // than an array of {x,y,vx,vy,theta} objects: contiguous memory, far smaller
    // heap, and almost no per-frame GC churn at tens of thousands of particles.
    // `count` is the live particle count (arrays are allocated to MAX_PARTICLES
    // once and reused; we never reallocate per resize, just change `count`).
    let px = new Float32Array(0);
    let py = new Float32Array(0);
    let pvx = new Float32Array(0);
    let pvy = new Float32Array(0);
    // Per-particle render group, reused each frame (0=gas, 1=name, 2=JR). Filled
    // by render()'s single classification pass; avoids re-evaluating isInside* in
    // each draw pass AND avoids allocating anything per frame.
    let pgroup = new Uint8Array(0);
    let count = 0;

    // Pre-computed pool of unit Gaussian random numbers. Generating ~200k random
    // values per frame (one per axis per particle) via Math.random()+Box-Muller in
    // the hot loop bottlenecks Firefox badly. Instead we fill this pool ONCE and
    // pull from it by index with a cheap bitwise wrap. The pool is far larger than
    // the per-frame draw and we advance the start offset each frame, so particles
    // don't visibly reuse the same kick pattern. Power-of-two size → mask wrap.
    const RANDOM_POOL_SIZE = 1 << 16; // 65536
    const RANDOM_MASK = RANDOM_POOL_SIZE - 1;
    const randomPool = new Float32Array(RANDOM_POOL_SIZE);
    let poolCursor = 0; // advanced per frame so the noise isn't perfectly periodic
    function fillRandomPool() {
      for (let i = 0; i < RANDOM_POOL_SIZE; i++) randomPool[i] = gaussian();
    }
    let raf: number | null = null;
    let last = 0;
    let running = false;
    // The intro's simulation phase (gas fade-in + activation flicker) begins at
    // the SAME absolute time as the CSS sim fade — the --intro-sim-at custom
    // property on <html data-home-intro> (which can overlap Phase 2). Custom
    // properties read back via getComputedStyle are UNRESOLVED (e.g. the literal
    // "calc(...)"), so we can't just parse it. Instead we let the browser resolve
    // it for us: set it as an animation-delay on a throwaway probe element and
    // read the resolved seconds back. This keeps JS perfectly in lockstep with
    // the CSS no matter how --intro-sim-at is authored.
    function readSimIntroDelayMs(): number {
      const FALLBACK = 1750;
      try {
        const probe = document.createElement("div");
        probe.style.position = "absolute";
        probe.style.animationName = "introCanvasFade";
        probe.style.animationDuration = "1s";
        // var() resolves against <html> where --intro-sim-at is defined.
        probe.style.animationDelay = "var(--intro-sim-at)";
        document.documentElement.appendChild(probe);
        const resolved = getComputedStyle(probe).animationDelay; // e.g. "1.75s"
        probe.remove();
        const v = resolved.endsWith("ms")
          ? parseFloat(resolved)
          : parseFloat(resolved) * 1000;
        return isFinite(v) ? v : FALLBACK;
      } catch {
        return FALLBACK;
      }
    }
    let introStart: number | null = document.documentElement.hasAttribute(
      "data-home-intro",
    )
      ? performance.now() + readSimIntroDelayMs()
      : null;
    // The particle canvas is centered in the viewport and capped to a laptop-like
    // width so huge monitors don't dilute the fixed particle budget. canvasLeft
    // is the canvas's left in viewport coords, used to convert viewport positions
    // into canvas-local coords.
    let canvasLeft = 0;

    // Wall field: a downsampled grid storing distance-to-glyph and the outward
    // gradient (wall normal). Built from the rendered name's alpha mask.
    const FIELD_STEP = 3; // px per field cell (downsample for speed)
    let fieldW = 0;
    let fieldH = 0;
    let dist: Float32Array = new Float32Array(0); // signed distance (px), <0 inside glyph
    // Parallel mask for the small "JR" superscript: 1 where a cell is inside a JR
    // glyph. Particles there are colored magenta to echo the logo's pink glyphs.
    let jrMask: Uint8Array = new Uint8Array(0);

    // Colors, re-read on theme change. Particles drift freely everywhere; the
    // ONLY thing the glyphs do is recolor a particle while it's inside a letter.
    // So the name is spelled out by the inside-color particles passing through.
    let dotColor = "#888"; // outside the text: subtle ambient gas
    let insideColor = "#003366"; // inside a letter: the heading accent color
    // "JR" superscript color — the logo's pink, so the sim echoes the brand.
    const JR_COLOR = "#ff49ff";
    const clamp01 = (v: number) => Math.min(1, Math.max(0, v));
    function introElapsed() {
      if (introStart === null) return Infinity;
      if (!document.documentElement.hasAttribute("data-home-intro")) {
        introStart = null;
        return Infinity;
      }
      return performance.now() - introStart;
    }
    // t is ms since the sim intro phase began (canvas starting to appear);
    // negative before that. The GAS fades in uniformly (no flicker) over the
    // first ~600ms; during this the name is INVISIBLE (activation still 0), so
    // there's a clear "uniform gas, no name" beat before the name ignites.
    function ambientIntroAlpha(t: number) {
      if (!isFinite(t)) return 1;
      if (t <= 0) return 0;
      return clamp01(t / 600);
    }
    // The ACTIVATION (inside-name color+glow) ignites like a neon tube AFTER the
    // gas is fully up: held off through the gas fade, then a few stutter pulses,
    // then settles fully on. This is the ONLY thing that flickers — the gas and
    // grid never do.
    function activatedIntroAlpha(t: number) {
      if (!isFinite(t)) return 1;
      if (t < 750) return 0; // gas-only beat; name hidden
      if (t < 800) return 0.25; // first stutter on
      if (t < 870) return 0; // off
      if (t < 915) return 0.7; // flick
      if (t < 955) return 0.05; // off
      if (t < 1010) return 0.9; // bright flick
      if (t < 1055) return 0.18; // dip
      if (t < 1110) return 0.55; // half flick
      if (t < 1150) return 0.1; // off
      if (t < 1210) return 1; // on
      if (t < 1255) return 0.45; // final little stutter
      return 1; // settled, fully lit
    }
    function readColors() {
      const cs = getComputedStyle(document.documentElement);
      // Inside-text color = the color used for headings in this theme.
      insideColor = cs.getPropertyValue("--color-accent").trim() || "#003366";
      // Outside (ambient gas): muted in dark mode, but in light mode the muted
      // text color is too dark and competes with the navy letters — use the
      // light border gray so the activated letters clearly stand out.
      const isDark =
        document.documentElement.getAttribute("data-theme") === "dark";
      dotColor = isDark
        ? DARK_GAS || cs.getPropertyValue("--color-text-muted").trim() || "#888"
        : LIGHT_GAS;
    }

    // ---- Particle sprites (GLOWING groups only) -------------------------
    // The expensive per-frame cost was ctx.shadowBlur, which only ever applied to
    // the GLOWING groups (name + JR). We bake those two sprites ONCE here (the
    // only place shadowBlur is touched) and blit them with drawImage per frame.
    // The ambient GAS is NOT a sprite: it has no glow and a 1px dot scaled out of
    // a padded sprite box gets bilinear-smeared into a soft gray blob (the muddy
    // look). The gas keeps its original crisp batched rect-path + single fill,
    // which was never the bottleneck. Sprites are sized to THEIR OWN content
    // (dot + glow halo) and DPR-scaled; the blit dest size is each sprite's css.
    // Sprites indexed by render group: 0=gas (tiny, no glow), 1=name (glow),
    // 2=JR (glow). The gas sprite is new for the WebGL path — every group goes
    // through the same point-sprite pipeline. (The Canvas2D fallback still draws
    // the gas as a crisp rect-path; the gas sprite is only used by WebGL.)
    const sprites: (HTMLCanvasElement | null)[] = [null, null, null];
    // Per-group CSS point size (square sprite edge). Gas is small; glow groups
    // are dot+halo. Used as gl_PointSize per group AND as the 2D blit dest size.
    const spriteSizes: number[] = [0, 0, 0];
    let spriteCssSize = 0; // glow sprite edge (name/JR) — also 2D blit size
    let spriteHalf = 0; // half of spriteCssSize (center offset, 2D path)
    function bakeSprite(
      color: string,
      glow: number,
      cssSize: number,
    ): HTMLCanvasElement {
      // Sprite holds the dot plus room for the glow halo on every side. Drawn at
      // device resolution (DPR) so the dot stays crisp, blit back to CSS px.
      //
      // COHESION: the original live drop-shadow looked like one continuous body
      // because each particle's halo was DENSE (it stacked the shadow with a
      // double fill), so where neighbouring halos overlapped they saturated into a
      // solid glow rather than reading as separate soft dots. We recreate that by
      // stacking the shadow GLOW_STACK times into the baked sprite: a denser,
      // more opaque halo that merges with its neighbours when blitted. Cost is
      // paid ONCE here, not per frame.
      const r = dotRadius();
      const dev = Math.max(1, Math.round(cssSize * DPR));
      const c = document.createElement("canvas");
      c.width = dev;
      c.height = dev;
      const sc = c.getContext("2d");
      if (sc) {
        sc.setTransform(DPR, 0, 0, DPR, 0, 0);
        const cx = cssSize / 2;
        const s = r * 2;
        sc.fillStyle = color;
        if (glow > 0) {
          sc.shadowColor = color;
          sc.shadowBlur = glow;
          // Stack the glow so the halo is dense enough to merge with neighbours.
          for (let k = 0; k < GLOW_STACK; k++)
            sc.fillRect(cx - r, cx - r, s, s);
        } else {
          sc.fillRect(cx - r, cx - r, s, s);
        }
      }
      return c;
    }
    function buildSprites() {
      // Reads the theme colors resolved by readColors() (dotColor / insideColor /
      // JR_COLOR) — no color logic of its own, so light & dark stay correct. Must
      // be called AFTER readColors() and after resize() (depends on DPR/dotRadius).
      const r = dotRadius();
      spriteCssSize = Math.ceil((r + GLOW) * 2); // dot + glow halo on all sides
      spriteHalf = spriteCssSize / 2;
      // Gas sprite is small (just the dot, no glow); pad by 1px so the point
      // sprite's edges aren't clipped by texture filtering.
      const gasCss = Math.ceil(r * 2) + 2;
      spriteSizes[0] = gasCss;
      spriteSizes[1] = spriteCssSize;
      spriteSizes[2] = spriteCssSize;
      sprites[0] = bakeSprite(dotColor, 0, gasCss); // gas — dot, no glow
      sprites[1] = bakeSprite(insideColor, GLOW, spriteCssSize); // name + glow
      sprites[2] = bakeSprite(JR_COLOR, GLOW, spriteCssSize); // JR + glow
      if (useGL) uploadTextures();
    }

    // ---- WebGL renderer -------------------------------------------------
    // Draws all particles as textured POINT sprites: positions uploaded once per
    // frame into a single buffer, then ONE gl.drawArrays per render group (3 total
    // instead of ~60k Canvas2D calls). The per-group texture is the SAME baked
    // sprite the Canvas2D path uses, so the glow is pixel-identical. Blending is
    // premultiplied-over to reproduce the Canvas2D source-over + alpha look,
    // including the halo build-up where neighbours overlap (the cohesion effect).
    let glProgram: WebGLProgram | null = null;
    let glPosBuf: WebGLBuffer | null = null;
    let glAttribPos = -1;
    let glUResolution: WebGLUniformLocation | null = null;
    let glUPointSize: WebGLUniformLocation | null = null;
    let glUAlpha: WebGLUniformLocation | null = null;
    let glUTex: WebGLUniformLocation | null = null;
    let glUDpr: WebGLUniformLocation | null = null;
    const glTextures: (WebGLTexture | null)[] = [null, null, null];
    // Scratch buffer of (x,y) pairs, packed sorted-by-group each frame so every
    // group is a contiguous vertex range drawable in one call. Sized to the cap.
    let glPacked = new Float32Array(0);
    // Per-group [start, length] into glPacked, filled by packGroups().
    const glGroupStart = [0, 0, 0];
    const glGroupLen = [0, 0, 0];
    let glMaxPointSize = 1024;

    function compileShader(type: number, src: string): WebGLShader | null {
      if (!gl) return null;
      const sh = gl.createShader(type);
      if (!sh) return null;
      gl.shaderSource(sh, src);
      gl.compileShader(sh);
      if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS)) {
        gl.deleteShader(sh);
        return null;
      }
      return sh;
    }

    function initGL(): boolean {
      if (!gl) return false;
      const vsSrc = `
        attribute vec2 aPos;       // particle position in CSS px (origin top-left)
        uniform vec2 uResolution;  // canvas size in CSS px
        uniform float uPointSize;  // sprite edge in CSS px
        uniform float uDpr;        // device pixel ratio
        void main() {
          // CSS px → clip space. Y is flipped (canvas top-left → GL bottom-left).
          vec2 clip = (aPos / uResolution) * 2.0 - 1.0;
          clip.y = -clip.y;
          gl_Position = vec4(clip, 0.0, 1.0);
          gl_PointSize = uPointSize * uDpr;
        }`;
      const fsSrc = `
        precision mediump float;
        uniform sampler2D uTex;
        uniform float uAlpha;
        void main() {
          // Sprite textures are premultiplied; scale by the group/intro alpha.
          vec4 t = texture2D(uTex, gl_PointCoord);
          gl_FragColor = t * uAlpha;
        }`;
      const vs = compileShader(gl.VERTEX_SHADER, vsSrc);
      const fs = compileShader(gl.FRAGMENT_SHADER, fsSrc);
      if (!vs || !fs) return false;
      const prog = gl.createProgram();
      if (!prog) return false;
      gl.attachShader(prog, vs);
      gl.attachShader(prog, fs);
      gl.linkProgram(prog);
      gl.deleteShader(vs);
      gl.deleteShader(fs);
      if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
        gl.deleteProgram(prog);
        return false;
      }
      glProgram = prog;
      glAttribPos = gl.getAttribLocation(prog, "aPos");
      glUResolution = gl.getUniformLocation(prog, "uResolution");
      glUPointSize = gl.getUniformLocation(prog, "uPointSize");
      glUAlpha = gl.getUniformLocation(prog, "uAlpha");
      glUTex = gl.getUniformLocation(prog, "uTex");
      glUDpr = gl.getUniformLocation(prog, "uDpr");
      glPosBuf = gl.createBuffer();
      glPacked = new Float32Array(MAX_PARTICLES * 2);

      // Premultiplied-alpha over-blend (matches Canvas2D source-over + globalAlpha).
      gl.enable(gl.BLEND);
      gl.blendFunc(gl.ONE, gl.ONE_MINUS_SRC_ALPHA);
      gl.disable(gl.DEPTH_TEST);
      // Defensive: clamp point size to the hardware max (some mobile GPUs cap it).
      const range = gl.getParameter(gl.ALIASED_POINT_SIZE_RANGE);
      if (range && range[1]) glMaxPointSize = range[1];
      return true;
    }

    function makeTexture(src: HTMLCanvasElement): WebGLTexture | null {
      if (!gl) return null;
      const tex = gl.createTexture();
      gl.bindTexture(gl.TEXTURE_2D, tex);
      // Premultiply so the baked semi-transparent halo blends correctly.
      gl.pixelStorei(gl.UNPACK_PREMULTIPLY_ALPHA_WEBGL, true);
      gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, src);
      // Linear filtering for a smooth sprite; clamp so edges don't wrap.
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
      return tex;
    }

    function uploadTextures() {
      if (!gl) return;
      for (let g = 0; g < 3; g++) {
        const src = sprites[g];
        if (!src) continue;
        if (glTextures[g]) gl.deleteTexture(glTextures[g]);
        glTextures[g] = makeTexture(src);
      }
    }

    // Pack particle positions into glPacked sorted by group, recording each
    // group's contiguous [start,len] range so it can be drawn in one call.
    // During the intro pre-light, name/JR particles are packed into the GAS group
    // so they render as gas until activation lights them.
    function packGroups(preLight: boolean) {
      const n = count;
      // Count per group first (so we can lay out contiguous ranges).
      let c0 = 0,
        c1 = 0,
        c2 = 0;
      if (preLight) {
        c0 = n; // everything draws as gas
      } else {
        for (let i = 0; i < n; i++) {
          const g = pgroup[i];
          if (g === 0) c0++;
          else if (g === 1) c1++;
          else c2++;
        }
      }
      glGroupStart[0] = 0;
      glGroupStart[1] = c0;
      glGroupStart[2] = c0 + c1;
      glGroupLen[0] = c0;
      glGroupLen[1] = c1;
      glGroupLen[2] = c2;
      // Write cursors (in vertex units) for each group.
      let w0 = glGroupStart[0],
        w1 = glGroupStart[1],
        w2 = glGroupStart[2];
      const P = glPacked;
      const X = px;
      const Y = py;
      if (preLight) {
        for (let i = 0; i < n; i++) {
          const o = w0++ * 2;
          P[o] = X[i];
          P[o + 1] = Y[i];
        }
      } else {
        for (let i = 0; i < n; i++) {
          const g = pgroup[i];
          let o: number;
          if (g === 0) o = w0++ * 2;
          else if (g === 1) o = w1++ * 2;
          else o = w2++ * 2;
          P[o] = X[i];
          P[o + 1] = Y[i];
        }
      }
    }

    function drawGroup(g: number, alpha: number) {
      if (!gl || alpha <= 0 || glGroupLen[g] === 0) return;
      const tex = glTextures[g];
      if (!tex) return;
      gl.activeTexture(gl.TEXTURE0);
      gl.bindTexture(gl.TEXTURE_2D, tex);
      gl.uniform1i(glUTex, 0);
      gl.uniform1f(
        glUPointSize,
        Math.min(spriteSizes[g], glMaxPointSize / DPR),
      );
      gl.uniform1f(glUAlpha, alpha);
      gl.drawArrays(gl.POINTS, glGroupStart[g], glGroupLen[g]);
    }

    // ---- Wall field construction ---------------------------------------
    // Render the name to an offscreen canvas matching the on-screen <h1>'s box
    // and typography, read its alpha mask, then run a two-pass chamfer distance
    // transform to get distance + gradient everywhere.
    function buildField() {
      if (W === 0 || H === 0) return;
      fieldW = Math.max(1, Math.ceil(W / FIELD_STEP));
      fieldH = Math.max(1, Math.ceil(H / FIELD_STEP));
      const n = fieldW * fieldH;

      const off = document.createElement("canvas");
      off.width = fieldW;
      off.height = fieldH;
      const octx = off.getContext("2d");
      if (!octx) return;

      // Draw each visible name line into the mask at the SAME place the browser
      // paints it, so the particle wall matches the text exactly. We read each
      // line span's own box + computed font and center its real ink box (from
      // measureText) on the span's center — canvas "middle" baseline doesn't
      // match CSS line-height:1 centering for serif fonts (asymmetric
      // ascent/descent), which would otherwise offset the SDF from the text.
      const cs = getComputedStyle(nameEl);
      const scale = 1 / FIELD_STEP;
      const family = cs.fontFamily || "Georgia, serif";
      const weight = cs.fontWeight || "700";
      octx.fillStyle = "#fff";
      octx.textAlign = "center";
      octx.textBaseline = "alphabetic";

      // Convert each name line's viewport rect into canvas-local space. The
      // canvas may be narrower than the viewport on large screens, so subtract
      // canvasLeft for x; y is measured from the sim box top.
      const boxRect = root.getBoundingClientRect();
      // Track the last line's ink box so the "JR" superscript can be placed just
      // off its top-right corner without disturbing the name's own layout.
      let lastLineRight = 0;
      let lastLineTop = 0;
      let lastFontPx = 64;
      for (const lineEl of lineEls) {
        const lcs = getComputedStyle(lineEl);
        const fontPx =
          parseFloat(lcs.fontSize) || parseFloat(cs.fontSize) || 64;
        octx.font = `${weight} ${fontPx * scale}px ${family}`;
        const r = lineEl.getBoundingClientRect();
        const cx = (r.left - canvasLeft + r.width / 2) * scale;
        const centerY = (r.top - boxRect.top + r.height / 2) * scale;
        const text = (lineEl.textContent || "").trim();
        const m = octx.measureText(text);
        const baselineY =
          centerY +
          (m.actualBoundingBoxAscent - m.actualBoundingBoxDescent) / 2;
        octx.fillText(text, cx, baselineY);
        // Real ink right edge (centered text → center ± half the measured width).
        const inkHalf =
          (m.actualBoundingBoxLeft + m.actualBoundingBoxRight || m.width) / 2;
        lastLineRight = cx + inkHalf;
        lastLineTop = (r.top - boxRect.top) * scale;
        lastFontPx = fontPx;
      }

      const data = octx.getImageData(0, 0, fieldW, fieldH).data;
      const inside = new Uint8Array(n);
      for (let i = 0; i < n; i++) inside[i] = data[i * 4 + 3] > 40 ? 1 : 0;

      // --- "JR" superscript mask (magenta particles; echoes the logo) --------
      // Drawn on its own pass into a cleared offscreen, so it never perturbs the
      // name's size/position/spacing. Placed just off the last line's top-right.
      jrMask = new Uint8Array(n);
      octx.clearRect(0, 0, fieldW, fieldH);
      const jrPx = lastFontPx * 0.4 * scale; // small superscript
      octx.font = `${weight} ${jrPx}px ${family}`;
      octx.textAlign = "left";
      octx.textBaseline = "alphabetic";
      // Sit it as a superscript: x just past the last line's right edge, baseline
      // near the cap height of that line (top + ~0.5em of the small glyph).
      const jrX = lastLineRight + jrPx * 0.28;
      const jrBaseline = lastLineTop + jrPx * 1.0;
      octx.fillText("JR", jrX, jrBaseline);
      const jrData = octx.getImageData(0, 0, fieldW, fieldH).data;
      for (let i = 0; i < n; i++) jrMask[i] = jrData[i * 4 + 3] > 40 ? 1 : 0;
      // Restore name-drawing defaults (not strictly needed past here).
      octx.textAlign = "center";

      const idx = (x: number, y: number) => y * fieldW + x;
      const INF = 1e9;
      const D1 = 1; // orthogonal cost
      const D2 = Math.SQRT2; // diagonal cost

      // Chamfer distance transform: distance from every cell to the nearest cell
      // where `seed[i] === 1`. Two passes (forward + backward).
      const chamfer = (seed: Uint8Array) => {
        const d = new Float32Array(n);
        for (let i = 0; i < n; i++) d[i] = seed[i] ? 0 : INF;
        for (let y = 0; y < fieldH; y++) {
          for (let x = 0; x < fieldW; x++) {
            let v = d[idx(x, y)];
            if (x > 0) v = Math.min(v, d[idx(x - 1, y)] + D1);
            if (y > 0) v = Math.min(v, d[idx(x, y - 1)] + D1);
            if (x > 0 && y > 0) v = Math.min(v, d[idx(x - 1, y - 1)] + D2);
            if (x < fieldW - 1 && y > 0)
              v = Math.min(v, d[idx(x + 1, y - 1)] + D2);
            d[idx(x, y)] = v;
          }
        }
        for (let y = fieldH - 1; y >= 0; y--) {
          for (let x = fieldW - 1; x >= 0; x--) {
            let v = d[idx(x, y)];
            if (x < fieldW - 1) v = Math.min(v, d[idx(x + 1, y)] + D1);
            if (y < fieldH - 1) v = Math.min(v, d[idx(x, y + 1)] + D1);
            if (x < fieldW - 1 && y < fieldH - 1)
              v = Math.min(v, d[idx(x + 1, y + 1)] + D2);
            if (x > 0 && y < fieldH - 1)
              v = Math.min(v, d[idx(x - 1, y + 1)] + D2);
            d[idx(x, y)] = v;
          }
        }
        return d;
      };

      // Signed distance field: distance to the glyph edge, negative INSIDE the
      // glyph, positive outside. dOut = distance from outside cells to the glyph;
      // dIn = distance from inside cells to the background. Combining the two
      // gives a real inward distance (so the gradient points outward everywhere
      // inside a letter, not just in a thin shell).
      const notInside = new Uint8Array(n);
      for (let i = 0; i < n; i++) notInside[i] = inside[i] ? 0 : 1;
      const dOut = chamfer(inside); // 0 on glyph, grows outward
      const dIn = chamfer(notInside); // 0 on background, grows inward

      dist = new Float32Array(n);
      for (let i = 0; i < n; i++) {
        dist[i] = inside[i]
          ? -dIn[i] * FIELD_STEP // negative inside
          : dOut[i] * FIELD_STEP; // positive outside
      }
    }

    // Position → field-cell classification is inlined in render()'s single
    // per-particle pass (cached locals, no function-call overhead × ~100k).

    // ---- Sizing ---------------------------------------------------------
    function resize() {
      const rect = root.getBoundingClientRect();
      const prevW = W;
      const prevH = H;
      const viewportW = document.documentElement.clientWidth;
      // Width is capped and centered on large screens; smaller screens keep the
      // full viewport width. The grid remains viewport-wide in CSS.
      W = Math.min(viewportW, MAX_SIM_W);
      H = rect.height;
      canvasLeft = (viewportW - W) / 2;
      // Position the centered canvas relative to the sim box.
      canvas.style.left = canvasLeft - rect.left + "px";
      canvas.style.width = W + "px";
      canvas.style.height = H + "px";
      canvas.width = Math.round(W * DPR);
      canvas.height = Math.round(H * DPR);
      if (gl) gl.viewport(0, 0, canvas.width, canvas.height);
      else if (ctx) ctx.setTransform(DPR, 0, 0, DPR, 0, 0);

      // Rescale existing particles to the new domain so the gas stays UNIFORM
      // across a resize. Without this, the canvas grows/shrinks but the old
      // positions keep their pixel coords, leaving dense and empty bands.
      if (prevW > 0 && prevH > 0 && count) {
        const sx = W / prevW;
        const sy = H / prevH;
        for (let i = 0; i < count; i++) {
          px[i] *= sx;
          py[i] *= sy;
        }
      }

      clearEdgeFade(); // gradient depends on W/H
      buildField();
      buildSprites(); // dot radius can change at the mobile breakpoint
      seedParticles();
    }

    // ---- Particles ------------------------------------------------------
    function seedParticles() {
      // Allocate the typed arrays ONCE (to the perf cap) and reuse them; resizes
      // only change `count`, never reallocate, so there's no per-resize GC.
      if (px.length === 0) {
        px = new Float32Array(MAX_PARTICLES);
        py = new Float32Array(MAX_PARTICLES);
        pvx = new Float32Array(MAX_PARTICLES);
        pvy = new Float32Array(MAX_PARTICLES);
        pgroup = new Uint8Array(MAX_PARTICLES);
        fillRandomPool();
      }
      const want = Math.min(targetCount(), MAX_PARTICLES);
      // Top up new particles (spawn anywhere — they pass through letters freely).
      // Existing particles keep their state; we only grow/shrink the live `count`.
      for (let i = count; i < want; i++) {
        px[i] = Math.random() * W;
        py[i] = Math.random() * H;
        pvx[i] = 0;
        pvy[i] = 0;
      }
      count = want;
    }

    // ---- Pointer --------------------------------------------------------
    const cursor: Vec & { active: boolean } = { x: 0, y: 0, active: false };
    function onMove(e: PointerEvent) {
      // Particle coords live in canvas space: x is relative to the centered
      // canvas, y is measured from the sim box top.
      const rect = root.getBoundingClientRect();
      cursor.x = e.clientX - canvasLeft;
      cursor.y = e.clientY - rect.top;
      cursor.active = true;
    }
    function onLeave() {
      cursor.active = false;
    }

    // One-shot radial explosion from the last click. `strength` decays each frame
    // (BLAST_DECAY) until it falls below a tiny threshold, at which point the blast
    // is inert and the loop skips it. A new click just overwrites it (one blast at
    // a time keeps the hot loop's branch cheap).
    const blast = { x: 0, y: 0, strength: 0 };
    function onDown(e: PointerEvent) {
      const rect = root.getBoundingClientRect();
      blast.x = e.clientX - canvasLeft;
      blast.y = e.clientY - rect.top;
      blast.strength = BLAST_PUSH;
      // Wake the sim if it was paused (e.g. tab refocus) so the blast animates.
      start();
    }

    // ---- Step + render --------------------------------------------------
    // Pure Brownian motion: the gas is a cloud of independent particles, each
    // kicked by a random force every frame (no orientation, no self-propulsion,
    // no neighbours → O(N), no trig). Random kicks come from a precomputed pool
    // (table lookup + bitwise wrap) instead of Math.random() in the loop, which
    // is the single biggest Firefox win here.
    //
    // Everything the loop reads is cached into a LOCAL const before the loop
    // opens. Reaching out to closure/object scope (cursor.x, W, this-canvas
    // config) on every one of ~100k iterations forces the JS engine — Safari's
    // especially — to repeatedly traverse scope chains; locals stay in registers.
    function step(dt: number) {
      const n = count;
      const w = W;
      const h = H;
      const diff = DIFFUSION * dt; // per-frame random-walk magnitude
      const damp = DAMP;
      const maxSp = MAX_SPEED;
      const curR = CURSOR_R;
      const curR2 = curR * curR;
      const curPush = CURSOR_PUSH;
      const curActive = cursor.active;
      const cx = cursor.x;
      const cy = cursor.y;
      // Click explosion: active only while strength is meaningful. The clamp is
      // lifted to BLAST_SPEED so the impulse actually shoots outward this frame.
      const blastActive = blast.strength > 1;
      const bx = blast.x;
      const by = blast.y;
      const blastR = BLAST_R;
      const blastR2 = blastR * blastR;
      const blastStr = blast.strength;
      const maxSpEff = blastActive ? BLAST_SPEED : maxSp;
      const pool = randomPool;
      const mask = RANDOM_MASK;
      // Advance the pool window each frame so the noise isn't perfectly periodic.
      let p = poolCursor;
      // Local aliases for the typed arrays (avoids re-reading the closure vars).
      const X = px;
      const Y = py;
      const VX = pvx;
      const VY = pvy;

      for (let i = 0; i < n; i++) {
        // Random Brownian kick: one pooled Gaussian per axis.
        let ax = pool[p++ & mask] * diff;
        let ay = pool[p++ & mask] * diff;

        // The glyphs exert NO force — particles pass through freely; the name is
        // revealed purely by recoloring inside-glyph particles (see render()).
        // Cursor repulsion well is the one interaction left.
        let x = X[i];
        let y = Y[i];
        if (curActive) {
          const dx = x - cx;
          const dy = y - cy;
          const d2 = dx * dx + dy * dy;
          if (d2 < curR2 && d2 > 0.01) {
            const d = Math.sqrt(d2);
            const f = (curPush * (1 - d / curR)) / d;
            ax += dx * f * dt;
            ay += dy * f * dt;
          }
        }

        // Click explosion: a one-shot radial impulse outward from the blast point,
        // strongest at the center and fading to zero at BLAST_R.
        if (blastActive) {
          const dx = x - bx;
          const dy = y - by;
          const d2 = dx * dx + dy * dy;
          if (d2 < blastR2 && d2 > 0.01) {
            const d = Math.sqrt(d2);
            const f = (blastStr * (1 - d / blastR)) / d;
            ax += dx * f * dt;
            ay += dy * f * dt;
          }
        }

        // Integrate velocity with damping + speed clamp (so the cursor push and
        // the random drift both decay rather than accumulating forever). During a
        // blast the clamp is raised (maxSpEff) so the explosion actually shoots.
        let vx = (VX[i] + ax) * damp;
        let vy = (VY[i] + ay) * damp;
        const sp2 = vx * vx + vy * vy;
        if (sp2 > maxSpEff * maxSpEff) {
          const s = maxSpEff / Math.sqrt(sp2);
          vx *= s;
          vy *= s;
        }
        VX[i] = vx;
        VY[i] = vy;
        x += vx * dt;
        y += vy * dt;

        // Toroidal wrap so the field stays full.
        if (x < 0) x += w;
        else if (x >= w) x -= w;
        if (y < 0) y += h;
        else if (y >= h) y -= h;
        X[i] = x;
        Y[i] = y;
      }
      // Step the window forward by a prime-ish stride so successive frames don't
      // realign to the same slice of the pool.
      poolCursor = (poolCursor + 1009) & mask;
      // Decay the click explosion so it's a one-shot burst that fades out.
      if (blastActive) {
        blast.strength *= BLAST_DECAY;
        if (blast.strength <= 1) blast.strength = 0;
      }
    }

    // SINGLE classification pass: evaluate inside/JR once per particle and record
    // its group in pgroup (0=gas, 1=name, 2=JR). Shared by both backends. Inlined
    // with cached locals (no per-particle function calls — scope traversal × ~60k
    // is exactly what Safari/Firefox penalize). Returns whether any name/JR exist.
    let classAnyInside = false;
    let classAnyJR = false;
    function classify() {
      let anyInside = false;
      let anyJR = false;
      const n = count;
      const X = px;
      const Y = py;
      const D = dist;
      const JR = jrMask;
      const G = pgroup;
      const fw = fieldW;
      const inv = 1 / FIELD_STEP;
      const maxX = fw - 1;
      const maxY = fieldH - 1;
      for (let i = 0; i < n; i++) {
        let fx = (X[i] * inv) | 0;
        let fy = (Y[i] * inv) | 0;
        if (fx < 0) fx = 0;
        else if (fx > maxX) fx = maxX;
        if (fy < 0) fy = 0;
        else if (fy > maxY) fy = maxY;
        const c = fy * fw + fx;
        let g = 0;
        if (JR[c] === 1) {
          g = 2;
          anyJR = true;
        } else if (D[c] < 0) {
          g = 1;
          anyInside = true;
        }
        G[i] = g;
      }
      classAnyInside = anyInside;
      classAnyJR = anyJR;
    }

    function render() {
      const introT = introElapsed();
      const introActive = isFinite(introT);
      const ambientAlpha = ambientIntroAlpha(introT);
      const activatedAlpha = activatedIntroAlpha(introT);
      classify();
      if (gl) renderGL(introActive, ambientAlpha, activatedAlpha);
      else if (ctx) render2D(introActive, ambientAlpha, activatedAlpha);
    }

    // WebGL draw: pack positions sorted-by-group, upload once, then ≤3 draw calls
    // (gas, name, JR) — vs ~60k Canvas2D calls. The edge fade is a CSS mask on the
    // canvas element (set in resize), so there's no per-frame fade pass here.
    function renderGL(
      introActive: boolean,
      ambientAlpha: number,
      activatedAlpha: number,
    ) {
      if (!gl || !glProgram) return;
      gl.clearColor(0, 0, 0, 0);
      gl.clear(gl.COLOR_BUFFER_BIT);
      gl.useProgram(glProgram);
      gl.uniform2f(glUResolution, W, H);
      gl.uniform1f(glUDpr, DPR);

      // During the intro pre-light, ALL particles render as gas until activation.
      const preLight = introActive && activatedAlpha <= 0;
      packGroups(preLight);

      gl.bindBuffer(gl.ARRAY_BUFFER, glPosBuf);
      const vertsUsed = (glGroupStart[2] + glGroupLen[2]) * 2 || count * 2;
      gl.bufferData(
        gl.ARRAY_BUFFER,
        glPacked.subarray(0, vertsUsed),
        gl.DYNAMIC_DRAW,
      );
      gl.enableVertexAttribArray(glAttribPos);
      gl.vertexAttribPointer(glAttribPos, 2, gl.FLOAT, false, 0, 0);

      // Gas (group 0) — also carries name/JR during the pre-light beat. Lower
      // per-particle alpha because GL gas overlaps accumulate (see GL_ALPHA_OUT).
      drawGroup(0, GL_ALPHA_OUT * ambientAlpha);
      if (!preLight) {
        if (classAnyInside) drawGroup(1, ALPHA_IN * activatedAlpha);
        if (classAnyJR) drawGroup(2, ALPHA_IN * activatedAlpha);
      }
    }

    // Canvas2D draw — STATIC FALLBACK only (used when WebGL is unavailable, and
    // for the reduced-motion single frame). Sprites: 1=name, 2=JR; gas is a crisp
    // batched rect-path. Mirrors the pre-WebGL renderer.
    function render2D(
      introActive: boolean,
      ambientAlpha: number,
      activatedAlpha: number,
    ) {
      if (!ctx) return;
      ctx.clearRect(0, 0, W, H);
      const sName = sprites[1];
      const sJR = sprites[2];
      const ssz = spriteCssSize;
      const soff = spriteHalf;
      const half = dotRadius();
      const sz = half * 2;
      ctx.beginPath();
      for (let i = 0; i < count; i++) {
        if (pgroup[i] === 0 || introActive) {
          ctx.rect(px[i] - half, py[i] - half, sz, sz);
        }
      }
      ctx.globalAlpha = ALPHA_OUT * ambientAlpha;
      ctx.fillStyle = dotColor;
      ctx.fill();

      if (classAnyInside && activatedAlpha > 0 && sName) {
        ctx.globalAlpha = ALPHA_IN * activatedAlpha;
        for (let i = 0; i < count; i++) {
          if (pgroup[i] === 1)
            ctx.drawImage(sName, px[i] - soff, py[i] - soff, ssz, ssz);
        }
      }
      if (classAnyJR && activatedAlpha > 0 && sJR) {
        ctx.globalAlpha = ALPHA_IN * activatedAlpha;
        for (let i = 0; i < count; i++) {
          if (pgroup[i] === 2)
            ctx.drawImage(sJR, px[i] - soff, py[i] - soff, ssz, ssz);
        }
      }

      // Edge fade (2D path): erase toward all four edges with two linear gradients.
      ctx.globalAlpha = 1;
      ctx.globalCompositeOperation = "destination-out";
      ctx.fillStyle = edgeFadeX()!;
      ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = edgeFadeY()!;
      ctx.fillRect(0, 0, W, H);
      ctx.globalCompositeOperation = "source-over";
    }

    // Cached edge-fade gradients (opaque at the rim → erases; clear in the
    // middle → keeps). One per axis; together they feather all four edges.
    // Rebuilt on resize via clearEdgeFade(). FADE is the fraction of each side
    // over which the fade happens (0.30 → outer 30% of each side feathers out).
    // On narrow (mobile) screens the box is much skinnier, so the same fraction
    // eats into the name — use a gentler horizontal fade there.
    const FADE = 0.3; // vertical (top/bottom) fade — plenty of room
    const fadeX = () => (W < 600 ? 0.16 : 0.3); // horizontal fade, gentler on mobile
    let _edgeFadeX: CanvasGradient | null = null;
    let _edgeFadeY: CanvasGradient | null = null;
    function clearEdgeFade() {
      _edgeFadeX = null;
      _edgeFadeY = null;
      // WebGL can't erase per-pixel cheaply per frame, so the GL path feathers the
      // canvas edges with a CSS mask instead (GPU-composited, no draw cost). The
      // 2D fallback bakes the fade into the canvas (below), so clear any mask there.
      if (useGL) applyEdgeMask();
      else canvas.style.removeProperty("mask-image");
    }
    function applyEdgeMask() {
      const fx = Math.round(fadeX() * 100);
      const fy = Math.round(FADE * 100);
      const maskX = `linear-gradient(to right, transparent 0, #000 ${fx}%, #000 ${100 - fx}%, transparent 100%)`;
      const maskY = `linear-gradient(to bottom, transparent 0, #000 ${fy}%, #000 ${100 - fy}%, transparent 100%)`;
      const style = canvas.style as any;
      style.webkitMaskImage = `${maskX}, ${maskY}`;
      style.webkitMaskComposite = "source-in";
      style.maskImage = `${maskX}, ${maskY}`;
      style.maskComposite = "intersect";
    }
    function edgeFadeX(): CanvasGradient | null {
      if (!ctx) return null;
      if (_edgeFadeX) return _edgeFadeX;
      const f = fadeX();
      const g = ctx.createLinearGradient(0, 0, W, 0);
      g.addColorStop(0, "rgba(0,0,0,1)"); // erase left edge
      g.addColorStop(f, "rgba(0,0,0,0)");
      g.addColorStop(1 - f, "rgba(0,0,0,0)");
      g.addColorStop(1, "rgba(0,0,0,1)"); // erase right edge
      _edgeFadeX = g;
      return g;
    }
    function edgeFadeY(): CanvasGradient | null {
      if (!ctx) return null;
      if (_edgeFadeY) return _edgeFadeY;
      const g = ctx.createLinearGradient(0, 0, 0, H);
      g.addColorStop(0, "rgba(0,0,0,1)"); // erase top edge
      g.addColorStop(FADE, "rgba(0,0,0,0)");
      g.addColorStop(1 - FADE, "rgba(0,0,0,0)");
      g.addColorStop(1, "rgba(0,0,0,1)"); // erase bottom edge
      _edgeFadeY = g;
      return g;
    }

    // Box-Muller normal.
    let spare: number | null = null;
    function gaussian() {
      if (spare !== null) {
        const v = spare;
        spare = null;
        return v;
      }
      let u = 0,
        v = 0,
        s = 0;
      do {
        u = Math.random() * 2 - 1;
        v = Math.random() * 2 - 1;
        s = u * u + v * v;
      } while (s === 0 || s >= 1);
      const m = Math.sqrt((-2 * Math.log(s)) / s);
      spare = v * m;
      return u * m;
    }

    // Fixed-timestep accumulator. requestAnimationFrame fires at the display's
    // refresh rate, which varies wildly across machines (60 / 120 / 144 / 240 Hz
    // — many MacBooks and gaming monitors are well above 60). If physics ran once
    // per rAF with the raw frame delta, the simulation would run faster on
    // high-refresh displays and the Brownian noise (whose variance scales with the
    // timestep) would look different on every machine. Instead we accumulate real
    // elapsed time and advance the physics in FIXED 60 Hz substeps, so the sim is
    // identical regardless of refresh rate and survives frame skips. We render
    // once per rAF after catching up.
    const FIXED_DT = 1 / 60;
    const MAX_FRAME = 1 / 12; // clamp huge gaps (backgrounded tab) → at most a
    //                           few substeps, never a runaway catch-up storm
    let accumulator = 0;
    function frame(now: number) {
      raf = null;
      if (!running) return;
      let elapsed = (now - last) / 1000;
      last = now;
      if (!isFinite(elapsed) || elapsed <= 0) elapsed = FIXED_DT;
      if (elapsed > MAX_FRAME) elapsed = MAX_FRAME;
      accumulator += elapsed;
      // Cap the number of catch-up substeps so a slow device (where each step
      // costs more than FIXED_DT) can't spiral into ever-growing backlogs.
      let steps = 0;
      while (accumulator >= FIXED_DT && steps < 4) {
        step(FIXED_DT);
        accumulator -= FIXED_DT;
        steps++;
      }
      if (steps === 4) accumulator = 0; // drop backlog; keep real-time, not slo-mo
      render();
      schedule();
    }
    function schedule() {
      if (raf == null) raf = requestAnimationFrame(frame);
    }

    function start() {
      if (running || reduceMotion) return;
      running = true;
      last = performance.now();
      schedule();
    }
    function stop() {
      running = false;
      if (raf != null) {
        cancelAnimationFrame(raf);
        raf = null;
      }
    }

    // ---- Wire up --------------------------------------------------------
    // Initialize the WebGL pipeline BEFORE resize()/buildSprites() (which upload
    // textures). If GL init fails after we already took the context (rare: shader
    // compile/link failure), we can't get a 2D context on the same canvas — so we
    // null out `gl` and let the renderer fall back to the static frame (the same
    // graceful path as a no-WebGL browser). The canvas just won't animate.
    // Init the GL pipeline before resize()/buildSprites() (which upload textures).
    // If it fails despite the probe (e.g. program link failure), drop to null and
    // the renderer leaves the static <h1> — extremely rare, no crash.
    if (gl && !initGL()) gl = null;

    readColors();
    resize();

    // No animated 2D fallback: when WebGL is unavailable (or failed to init), and
    // for reduced-motion, render ONE static relaxed frame and stop. Browsers
    // without WebGL are the low-power devices a 60k-particle 2D loop would choke,
    // so a crisp static hero is the better degradation.
    if (reduceMotion || !gl) {
      // Static frame: let the swarm relax a few steps so an outline still forms,
      // then draw once. No RAF. (If gl is null but ctx exists, render2D draws it;
      // if gl somehow survived but reduceMotion, renderGL draws one frame.)
      for (let k = 0; k < 80; k++) step(1 / 60);
      render();
    } else {
      // Pause when the hero scrolls offscreen.
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) start();
            else stop();
          }
        },
        { threshold: 0 },
      );
      io.observe(root);

      const onVisibility = () => {
        if (document.hidden) stop();
        else if (isOnScreen()) start();
      };
      document.addEventListener("visibilitychange", onVisibility);

      function isOnScreen() {
        const r = root.getBoundingClientRect();
        return r.bottom > 0 && r.top < window.innerHeight;
      }

      if (canHover) {
        root.addEventListener("pointermove", onMove);
        root.addEventListener("pointerleave", onLeave);
      }
      // Click/tap explosion works on both mouse and touch (a tap should burst too).
      root.addEventListener("pointerdown", onDown);

      // Debounced resize → rebuild field + canvas.
      let resizeT: number | null = null;
      const onResize = () => {
        if (resizeT) clearTimeout(resizeT);
        resizeT = window.setTimeout(resize, 150);
      };
      window.addEventListener("resize", onResize);

      // WebGL context loss (common on mobile: backgrounding, GPU reset, memory
      // pressure). Without handling, the tab returns to a BLANK canvas. We stop on
      // loss and rebuild all GL resources + resume on restore.
      const onContextLost = (e: Event) => {
        e.preventDefault(); // required so the context CAN be restored
        stop();
      };
      const onContextRestored = () => {
        if (!gl) return;
        if (initGL()) {
          buildSprites(); // re-bake + re-upload textures
          resize(); // re-set viewport + edge mask
          if (isOnScreen()) start();
        } else {
          gl = null; // give up; leave static <h1>
        }
      };
      canvas.addEventListener("webglcontextlost", onContextLost as any, false);
      canvas.addEventListener(
        "webglcontextrestored",
        onContextRestored as any,
        false,
      );

      // Rebuild the wall field once the webfont is ready (glyph metrics change).
      if ((document as any).fonts?.ready) {
        (document as any).fonts.ready.then(() => {
          buildField();
        });
      }

      // Recolor (and rebuild, in case weight/color changed) on theme toggle.
      // buildSprites() MUST run after readColors() so the rebaked sprites carry
      // the new theme's colors; the observer fires before the next rAF, so
      // render() never blits stale-colored sprites.
      const mo = new MutationObserver(() => {
        readColors();
        buildSprites();
        buildField();
      });
      mo.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });

      (window as any).__heroSimCleanup = () => {
        stop();
        io.disconnect();
        mo.disconnect();
        document.removeEventListener("visibilitychange", onVisibility);
        root.removeEventListener("pointermove", onMove);
        root.removeEventListener("pointerleave", onLeave);
        root.removeEventListener("pointerdown", onDown);
        window.removeEventListener("resize", onResize);
        canvas.removeEventListener("webglcontextlost", onContextLost as any);
        canvas.removeEventListener(
          "webglcontextrestored",
          onContextRestored as any,
        );
        if (resizeT) clearTimeout(resizeT);
        // Free GL resources so a swapped-away hero doesn't leak GPU memory.
        // NOTE: do NOT call WEBGL_lose_context.loseContext() here. Cleanup runs on
        // BOTH navigation-away AND re-init of the SAME canvas (initHeroSim calls
        // __heroSimCleanup first, and it runs twice on first load: module eval +
        // astro:page-load). getContext() on a canvas always returns the same
        // context object, and once force-lost it stays lost (recoverable only via
        // the async webglcontextrestored event), so loseContext() would leave the
        // re-init holding a dead context — a permanently blank canvas. Deleting the
        // resources is enough; the context is reclaimed by GC when the swapped-away
        // canvas element is dropped.
        if (gl) {
          for (const t of glTextures) if (t) gl.deleteTexture(t);
          if (glPosBuf) gl.deleteBuffer(glPosBuf);
          if (glProgram) gl.deleteProgram(glProgram);
        }
        delete (canvas as any).__heroSimBound;
        delete (window as any).__heroSimCleanup;
      };

      if (isOnScreen()) start();
    }
  }

  initHeroSim();
  document.addEventListener("astro:page-load", initHeroSim);
  // Stop the sim the instant we navigate AWAY from home (before the swap), so its
  // RAF loop never lingers into other pages or overlaps the next instance.
  document.addEventListener("astro:before-swap", () =>
    (window as any).__heroSimCleanup?.(),
  );
</script>

<style>
  .hero-sim {
    position: relative;
    /* Break OUT of the content column so the simulation is a touch wider than the
       text/buttons below it, giving the name more room to breathe. The negative
       inline margins pull it past the column on both sides (capped so it never
       causes horizontal scroll); width then fills the widened box. The grid
       bleeds even further past this (negative inset below) so it reads as part of
       the page background, not a framed panel. */
    --sim-bleed: clamp(0px, 6vw, 7rem);
    width: calc(100% + 2 * var(--sim-bleed));
    margin-inline: calc(-1 * var(--sim-bleed));
    min-height: 14rem;
    /* Establish a container so the name can size in cqw (panel-width units). */
    container-type: inline-size;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
    /* No border/clip: the panel blends into the page (soft edges below). */
  }

  /* Background grid. Mobile keeps the tuned, panel-local treatment below.
     Desktop overrides anchor it to the viewport so it reads as page background,
     not a framed simulation layer. */
  .hero-sim-grid {
    position: absolute;
    /* Tuned mobile/default footprint. Desktop gets a wider viewport-anchored
       treatment in the min-width override below. */
    inset: -22% -12%;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 46px 46px;
    background-position: center;
    opacity: 0.28; /* grid visibility — lower = fainter */
    /* Mobile/default keeps the existing radial feathering. */
    -webkit-mask-image: radial-gradient(
      ellipse 60% 65% at center,
      #000 25%,
      transparent 60%
    );
    mask-image: radial-gradient(
      ellipse 60% 65% at center,
      #000 25%,
      transparent 60%
    );
  }

  .hero-sim-canvas {
    position: absolute;
    /* JS sizes and centers this canvas. It spans the viewport on laptop/mobile
       and caps to a laptop-like width on large desktops, with baked edge fades
       preventing a hard rectangular boundary. */
    top: 0;
    bottom: 0;
    left: 0; /* overridden in JS via inline left/width to reach viewport edges */
    z-index: 2;
    pointer-events: none; /* never blocks buttons/links below */
    /* Soft edges are baked into the canvas pixels (radial destination-out fade
       in render()), which is robust across browsers/DPR — no CSS mask needed. */
  }

  .hero-sim-name {
    position: relative;
    z-index: 1; /* under the canvas: particles render over it */
    margin: 0;
    padding: 0 0.5rem;
    font-family: var(--font-serif);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 0.95;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* Size relative to the PANEL width (container query unit), not the viewport,
       so each line fills the column consistently at any window size — including
       mobile, where the name should nearly span the width. */
    font-size: min(20cqw, 8.5rem);
    /* COLOR-REVEAL: the name is spelled out by the accent-colored particles
       passing through the letters (rendered on the canvas above). The <h1> stays
       in the DOM for accessibility/SEO but is visually invisible AND inert — no
       text selection or I-beam cursor, so it doesn't break the sim illusion. */
    color: transparent;
    text-shadow: none;
    user-select: none;
    -webkit-user-select: none;
    cursor: default;
    pointer-events: none;
  }
  .hero-sim-line {
    display: block;
    white-space: nowrap; /* each line is one row (matches the SDF) */
  }

  @media (min-width: 769px) {
    .hero-sim {
      /* With the parent no longer clipping on desktop, keep the widened sim
         centered but never wider than the viewport. */
      width: min(calc(100% + 2 * var(--sim-bleed)), 100vw);
      margin-inline: 0;
      left: 50%;
      transform: translateX(-50%);
    }

    .hero-sim-grid {
      /* Full-bleed on desktop: the grid spans the viewport rather than the
         local panel, so it reads like a site background passing through the sim. */
      top: -18%;
      bottom: -18%;
      left: calc(50% - 50vw);
      width: 100vw;
      inset-inline: auto;
      background-size: 48px 48px;
      opacity: 0.24;
      /* Feather independently along each axis so all four edges dissolve
         evenly; a radial-only mask leaves the side midpoints too abrupt. */
      -webkit-mask-image:
        linear-gradient(
          to right,
          transparent 0,
          #000 18%,
          #000 82%,
          transparent 100%
        ),
        linear-gradient(
          to bottom,
          transparent 0,
          #000 20%,
          #000 80%,
          transparent 100%
        );
      -webkit-mask-composite: source-in;
      mask-image:
        linear-gradient(
          to right,
          transparent 0,
          #000 18%,
          #000 82%,
          transparent 100%
        ),
        linear-gradient(
          to bottom,
          transparent 0,
          #000 20%,
          #000 80%,
          transparent 100%
        );
      mask-composite: intersect;
    }
  }

  @media (max-width: 768px) {
    /* On mobile the name should fill most of the (narrow) column but leave a
       little air on each side so the edge fade doesn't clip the letters. */
    .hero-sim-name {
      font-size: min(20cqw, 5.25rem);
    }
    .hero-sim-grid {
      background-size: 34px 34px;
    }
  }
</style>
