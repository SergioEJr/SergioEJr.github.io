---
import HeaderLink from './HeaderLink.astro';
import { CV_URL, SITE_TITLE } from '../consts';
import { CV_AVAILABLE } from '../utils/cv';
import { url } from '../utils/paths';

const cvHref = CV_AVAILABLE && CV_URL ? url(CV_URL) : null;
---

<header>
	<nav>
		<h2>
            <a href={url('/')} class="brand">
                <span class="brand-logo" aria-hidden="true">
                    <svg class="brand-logo-image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 144.82 109.11">
                        <path class="brand-logo-primary" d="M22.95,97.66c-3.36,8.3-10.98,13.72-18.76,9.45-3.26-1.79-4.66-5.84-2.98-9.01,1.03-1.95,3.5-2.23,5.16-1.74,3.94,1.16,3.04,5.83,4.18,6.46,2.02,1.13,5.14-1.9,5.93-5.22.6-2.51,1.3-4.96,1.63-7.6,2.55-20.75,1.39-42.26,4.61-61.93C24.44,17.59,28.55-1.15,42.81.62c4.68.58,8.07,4.95,6.48,9.54-.78,2.27-3.34,3.07-5.22,2.49-4.67-1.43-2.49-6.32-4-6.99-3.2-1.43-6.06,4-6.94,7.79-1.85,7.94-2.28,15.86-2.47,24.12-.31,13.09-.7,25.74-2.34,38.67-.95,7.52-2.56,14.49-5.37,21.43Z"/>
                        <path class="brand-logo-primary" d="M54.95,71.42c4.98,5.61,15.87,4.46,21.31-1.06,1.23-.4,3.91,2.73,3.24,3.86-2.99,4.97-9.4,6.56-15.1,6.74-7.79.25-15.03-3.42-18.03-10.81-2.54-6.25-2.55-13.32-.74-19.81,2.36-8.43,10.15-13.25,18.74-12.88,5.96.26,11.43,2.76,14.13,8.17,2.3,4.6,2.9,9.84,2.07,15.1l-28.97.18c-.19,3.86.9,7.75,3.35,10.51ZM74.38,55.41c.1-4.12-1.36-7.33-3.89-10-4.42-3.05-10.51-3.09-14.74.46-2.78,2.34-4.1,6.09-4.18,9.56h22.81Z"/>
                        <path class="brand-logo-accent" d="M131.45,50.1c-1.07-.17-1.53-.82-1.62-1.36-.14-.79.59-1.43,1.61-1.51,8.04-.64-.06-12.52,6.62-16.5-6.38-3.6,1-16.33-6.09-16.14-.79.02-1.6-.18-1.89-.55-.35-.45-.35-1.42-.07-1.94.3-.58,1.15-.46,2-.52,3.89-.3,6.95,2.37,6.79,6.26l-.28,6.62c-.27,6.29,6.84,3.18,5.67,6.6-.18.54-1.06,1.05-1.98,1.2-5.12.84-3.08,5.34-3.45,11.81-.22,3.87-3.11,6.7-7.3,6.04Z"/>
                        <path class="brand-logo-accent" d="M122.37,42.62c-.59,1.07-14.33.65-14.89-.07-.39-.5-.3-2.21.49-2.2,1.49.01,2.69.32,4.22-.33l-.15-14.59c-1.46-.48-2.83-.1-4.42-.19-.35-.68-.47-2.22.15-2.4,1.78-.52,8.36-1.66,7.81,2.07,2.11-2.43,7.4-4.67,9.8-2.17,1.34,1.39,1.61,5.41.14,5.88-1.03.33-1.64-.18-2.01-1.29-.25-.75-.31-1.51-.75-1.94-.51-.49-1.47-.45-2.34-.24-6.97,1.69-4.47,8.55-4.67,14.92,1.81.81,5.86-.34,6.55.83.28.48.31,1.26.06,1.7Z"/>
                        <path class="brand-logo-accent" d="M87.98,48.79c1.82-1.13,4.52,1.04,7.36-.76.96-.61,1.92-2.07,1.93-3.74l.12-18.85c-2.68-.77-4.94.11-7.4-.33-.55-.1-.4-2.14.12-2.26,3.37-.74,6.8-1.07,10.61-.63l.11,20.78c.01,2.12-.41,4.66-1.91,6.27-2.82,3.03-8,3.83-11.49,1.67-.88-.54.11-1.87.57-2.15Z"/>
                        <path class="brand-logo-accent" d="M97.33,13.23c1.39-.53,2.5.45,2.81,1.25.59,1.49.16,3.08-.86,3.41-1.64.53-3.2.14-3.62-1.2s.11-2.87,1.67-3.46Z"/>
                    </svg>
                </span>
                <span>{SITE_TITLE}</span>
            </a>
        </h2>
        
		<div class="internal-links">
			<HeaderLink href={url('/')}>Home</HeaderLink>
			<HeaderLink href={url('/about')}>About</HeaderLink>
			<HeaderLink href={url('/publications')}>Research</HeaderLink>
			<HeaderLink href={url('/projects')}>Projects</HeaderLink>
			<HeaderLink href={url('/blog')}>Journal</HeaderLink>
		</div>

        <div class="header-actions">
            {cvHref && (
                <a href={cvHref} target="_blank" rel="noopener noreferrer" class="github-link" aria-label="Download CV" title="Download CV">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </a>
            )}
            <a href="https://github.com/SergioEJr" target="_blank" rel="noopener noreferrer" class="github-link" aria-label="GitHub" title="GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            </a>
            <button id="search-toggle-desktop" class="search-toggle" aria-label="Search site">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </button>
            <button id="theme-toggle" aria-label="Toggle Dark Mode">
                <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            </button>

            <button id="menu-toggle" aria-label="Toggle Menu">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
        </div>
	</nav>

    <div id="mobile-menu" class="mobile-menu hidden">
        <div class="mobile-menu-header">
            <span class="mobile-menu-title">Menu</span>
            <button id="search-toggle-mobile" class="search-toggle" aria-label="Search site">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </button>
        </div>
        <a href={url('/')}>Home</a>
        <a href={url('/about')}>About</a>
        <a href={url('/publications')}>Research</a>
        <a href={url('/projects')}>Projects</a>
        <a href={url('/blog')}>Journal</a>
        {cvHref && <a href={cvHref} target="_blank">Download CV</a>}
    </div>
</header>

<script>
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const newTheme = isDark ? 'light' : 'dark';
        (window as any).__setPreferredTheme?.(newTheme);
        localStorage.setItem('theme', newTheme);
    });

    document.getElementById('menu-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    document.querySelectorAll('.search-toggle').forEach((btn) => {
        btn.addEventListener('click', () => {
            document.dispatchEvent(new CustomEvent('open-search'));
        });
    });
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background-color: var(--color-bg-header);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
		position: sticky;
		top: 0;
		z-index: 100;
        transition: background-color 0.3s ease;
	}
    
    header::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, var(--color-border) 20%, var(--color-border) 80%, transparent 100%);
        opacity: 0.6;
    }

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-width);
		margin: 0 auto;
		height: 4.5rem;
	}
	h2 {
		margin: 0;
		font-size: 1.3em;
		font-family: var(--font-sans);
        font-weight: 700;
        letter-spacing: -0.02em;
        border-bottom: none;
        padding-bottom: 0;
        display: flex;
        align-items: center;
	}
	h2 a {
		text-decoration: none;
		color: var(--color-text-main);
        border: none;
	}
    .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        line-height: 1;
    }
    .brand:hover {
        opacity: 1;
        text-decoration: none;
    }
    .brand-logo {
        display: inline-flex;
        width: 2rem;
        height: 2rem;
        flex-shrink: 0;
        color: #101729;
    }
    .brand-logo-image {
        width: 100%;
        height: 100%;
        display: block;
    }
    .brand-logo-primary {
        fill: currentColor;
        stroke: currentColor;
        stroke-miterlimit: 10;
    }
    .brand-logo-accent {
        fill: #f0f;
        stroke: #f0f;
        stroke-miterlimit: 10;
    }
    :global(html[data-theme="dark"]) .brand-logo {
        color: #00deff;
    }

	.internal-links {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }
	.internal-links :global(a) {
		padding: 0.5em 0.75em;
		color: var(--color-text-main);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.2s ease;
	}
	.internal-links :global(a:hover) {
        color: var(--color-accent);
    }
	.internal-links :global(a.active) {
		text-decoration: none;
		border-bottom-color: var(--color-accent);
		color: var(--color-accent);
	}

    .dropdown {
        position: relative;
        display: inline-block;
    }
    .dropbtn {
        background-color: transparent;
        color: var(--color-text-main);
        padding: 0.5em 0.75em;
        font-size: 0.95rem;
        font-weight: 500;
        line-height: inherit;
        border: none;
        cursor: pointer;
        font-family: inherit;
        transition: all 0.2s ease;
        border-bottom: 2px solid transparent;
    }
    .dropdown:hover .dropbtn {
        color: var(--color-accent);
    }
    .dropdown-content {
        display: none;
        position: absolute;
        background-color: var(--color-bg-mobile-menu);
        backdrop-filter: blur(40px) saturate(150%);
        -webkit-backdrop-filter: blur(40px) saturate(150%);
        min-width: 120px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
        z-index: 1;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--color-header-border);
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
    }
    .dropdown-content :global(a) {
        color: var(--color-text-main);
        padding: 12px 16px;
        text-decoration: none;
        display: block;
        border-bottom: none;
    }
    .dropdown-content :global(a:hover) {
        background-color: var(--color-bg-offset);
    }
    .dropdown:hover .dropdown-content,
    .dropdown:focus-within .dropdown-content {
        display: block;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .search-toggle,
    #theme-toggle {
        background: transparent;
        border: none;
        cursor: pointer;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-main);
        transition: background-color 0.2s ease;
    }
    .search-toggle:hover,
    #theme-toggle:hover {
        background-color: var(--color-bg-offset);
        color: var(--color-accent);
    }

    .github-link {
        background: transparent;
        border: none;
        cursor: pointer;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-main);
        transition: background-color 0.2s ease;
    }

    .github-link:hover {
        background-color: var(--color-bg-offset);
        color: var(--color-accent);
    }

    .mobile-menu-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: 0.25rem;
        border-bottom: 1px solid var(--color-border);
        margin-bottom: 0.25rem;
    }
    .mobile-menu-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text-muted);
        padding-left: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    #menu-toggle {
        display: none;
        background: transparent;
        border: none;
        cursor: pointer;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-main);
    }

    .mobile-menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 1rem;
        width: fit-content;
        min-width: 180px;
        background-color: var(--color-bg-mobile-menu);
        backdrop-filter: blur(40px) saturate(150%);
        -webkit-backdrop-filter: blur(40px) saturate(150%);
        border: 1px solid var(--color-header-border);
        border-radius: 12px;
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.08);
        z-index: 200;
        animation: menuFadeIn 0.2s ease;
    }
    @keyframes menuFadeIn {
        from { opacity: 0; transform: translateY(-8px) scale(0.96); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .mobile-menu a {
        padding: 0.5rem 0.875rem;
        text-decoration: none;
        color: var(--color-text-main);
        font-weight: 500;
        font-size: 0.9rem;
        border-radius: 8px;
        transition: background-color 0.2s, color 0.2s;
    }
    .mobile-menu a:hover {
        background-color: var(--color-bg-offset);
        color: var(--color-accent);
    }
    .mobile-menu-section {
        padding: 0.5rem 0.875rem;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 0.5rem;
        border-top: 1px solid var(--color-border);
        padding-top: 0.75rem;
    }
    .mobile-submenu {
        display: flex;
        flex-direction: column;
        padding-left: 1rem;
        border-left: 2px solid var(--color-border);
        margin-left: 1rem;
        margin-bottom: 0.5rem;
    }
    .hidden { display: none; }
    
    .moon-icon { display: none; }
    .sun-icon { display: block; }
    :global(html[data-theme="dark"]) .moon-icon { display: block; }
    :global(html[data-theme="dark"]) .sun-icon { display: none; }

	@media (min-width: 721px) {
        #menu-toggle { display: none; }
        .mobile-menu { display: none !important; }
	}

	@media (max-width: 720px) {
		.internal-links { display: none; }
        #menu-toggle { display: flex; }
        #search-toggle-desktop { display: none !important; }
	}
</style>
