---
import HeaderLink from "./HeaderLink.astro";
import { CV_URL, SITE_TITLE } from "../consts";
import { CV_AVAILABLE } from "../utils/cv";
import { url } from "../utils/paths";
import logoSvg from "../../public/logo.svg?raw";

const cvHref = CV_AVAILABLE && CV_URL ? url(CV_URL) : null;

// The logo is a two-tone mark: the integral sign + "e" (the .cls-1 paths, #6cf)
// and the pink "f" glyphs (.cls-2). Each symbol gets its own neon glow, applied
// as a `filter: drop-shadow()`. Safari/WebKit doesn't reliably render `filter`
// on inner SVG nodes (paths/groups), so instead of one SVG with per-path
// filters we split the mark into two stacked <svg> layers — one per color — and
// filter the <svg> ELEMENT, which every browser handles. The two share the same
// viewBox so they overlay pixel-perfectly.
const stripped = logoSvg
  .replace(/<\?xml[^>]*>\s*/, "")
  // The integral/e is recolored via a CSS var so it can follow the theme; the
  // pink glyphs keep their color. Match both fill and stroke, with or without #.
  .replaceAll("#6cf", "var(--brand-logo-primary)")
  .replaceAll("#00deff", "var(--brand-logo-primary)");

// Keep only the <path> elements whose class matches `cls`, leaving <defs> (the
// shared <style>) and the <svg> wrapper intact so each layer renders identically
// to its slice of the original.
const layerFor = (keep: "cls-1" | "cls-2") =>
  stripped.replace(/<path\b[^>]*class="(cls-\d)"[^>]*\/>\s*/g, (m, cls) =>
    cls === keep ? m : "",
  );

const brandLayerPrimary = layerFor("cls-1");
const brandLayerSecondary = layerFor("cls-2");
---

<header class="site-header">
  <nav>
    <h2>
      <a href={url("/")} class="brand" aria-label={`${SITE_TITLE} — home`}>
        <span class="brand-logo" aria-hidden="true">
          <span class="brand-layer brand-layer-primary">
            <Fragment set:html={brandLayerPrimary} />
          </span>
          <span class="brand-layer brand-layer-secondary">
            <Fragment set:html={brandLayerSecondary} />
          </span>
        </span>
      </a>
    </h2>

    <div class="internal-links" transition:persist="internal-links">
      <HeaderLink href={url("/")}>Home</HeaderLink>
      <HeaderLink href={url("/publications")}>Research</HeaderLink>
      <HeaderLink href={url("/projects")}>Projects</HeaderLink>
      <HeaderLink href={url("/blog")}>Journal</HeaderLink>
      <HeaderLink href={url("/about")}>About</HeaderLink>
      <span class="nav-underline" aria-hidden="true"></span>
    </div>

    <div class="header-actions">
      {
        cvHref && (
          <a
            href={cvHref}
            target="_blank"
            rel="noopener noreferrer"
            class="github-link"
            aria-label="Download CV"
            title="Download CV"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
                <polyline points="10 9 9 9 8 9" />
              </>
            </svg>
          </a>
        )
      }
      <button
        id="search-toggle-desktop"
        class="search-toggle"
        aria-label="Search site"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="11" cy="11" r="8"></circle><line
            x1="21"
            y1="21"
            x2="16.65"
            y2="16.65"></line></svg
        >
      </button>
      <button id="theme-toggle" aria-label="Toggle Dark Mode">
        <svg
          class="sun-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="5"></circle><line
            x1="12"
            y1="1"
            x2="12"
            y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line
            x1="4.22"
            y1="4.22"
            x2="5.64"
            y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
          ></line><line x1="1" y1="12" x2="3" y2="12"></line><line
            x1="21"
            y1="12"
            x2="23"
            y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
          ></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg
        >
        <svg
          class="moon-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
          ></path></svg
        >
      </button>

      <button id="menu-toggle" aria-label="Toggle Menu">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="3" y1="12" x2="21" y2="12"></line><line
            x1="3"
            y1="6"
            x2="21"
            y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
        >
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu hidden">
    <div class="mobile-menu-header">
      <span class="mobile-menu-title">Menu</span>
      <button
        id="search-toggle-mobile"
        class="search-toggle"
        aria-label="Search site"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="11" cy="11" r="8"></circle><line
            x1="21"
            y1="21"
            x2="16.65"
            y2="16.65"></line></svg
        >
      </button>
    </div>
    <a href={url("/")}>Home</a>
    <a href={url("/publications")}>Research</a>
    <a href={url("/projects")}>Projects</a>
    <a href={url("/blog")}>Journal</a>
    <a href={url("/about")}>About</a>
    {
      cvHref && (
        <a href={cvHref} target="_blank">
          Download CV
        </a>
      )
    }
  </div>
</header>

<script>
  let headerControlsAbort: AbortController | null = null;

  function setupHeaderControls() {
    if (headerControlsAbort) headerControlsAbort.abort();
    headerControlsAbort = new AbortController();
    const { signal } = headerControlsAbort;

    document.getElementById("theme-toggle")?.addEventListener(
      "click",
      () => {
        const isDark =
          document.documentElement.getAttribute("data-theme") === "dark";
        const newTheme = isDark ? "light" : "dark";
        (window as any).__setPreferredTheme?.(newTheme);
        localStorage.setItem("theme", newTheme);
      },
      { signal },
    );

    document.getElementById("menu-toggle")?.addEventListener(
      "click",
      () => {
        document.getElementById("mobile-menu")?.classList.toggle("hidden");
      },
      { signal },
    );

    document.querySelectorAll(".search-toggle").forEach((btn) => {
      btn.addEventListener(
        "click",
        () => {
          document.dispatchEvent(new CustomEvent("open-search"));
        },
        { signal },
      );
    });

    setupNavUnderline(signal);
  }

  // Sliding underline under the active nav link. The `.internal-links`
  // container persists across client-side navigations (transition:persist), so
  // the same underline element survives the swap and animates from the old
  // link's position to the new one.
  function setupNavUnderline(signal: AbortSignal) {
    const nav = document.querySelector<HTMLElement>(".internal-links");
    const underline = nav?.querySelector<HTMLElement>(".nav-underline");
    if (!nav || !underline) return;

    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>("a"));

    const normalize = (path: string) => {
      const noBase = path.replace(/\/+$/, "");
      return noBase === "" ? "/" : noBase;
    };
    const here = normalize(location.pathname);

    // Find the link matching the current URL (longest matching prefix wins so
    // e.g. /blog/some-post highlights "Journal").
    let active: HTMLAnchorElement | null = null;
    let bestLen = -1;
    for (const a of links) {
      const target = normalize(new URL(a.href).pathname);
      const matches =
        target === here || (target !== "/" && here.startsWith(target + "/"));
      if (matches && target.length > bestLen) {
        bestLen = target.length;
        active = a;
      }
    }
    // Exact home match only (so "/" doesn't win on every page).
    if (here === "/") {
      active =
        links.find((a) => normalize(new URL(a.href).pathname) === "/") || active;
    }

    links.forEach((a) => a.classList.toggle("active", a === active));

    const moveTo = (el: HTMLElement | null, animate: boolean) => {
      if (!el) {
        underline.classList.remove("is-visible");
        return;
      }
      const navRect = nav.getBoundingClientRect();
      const rect = el.getBoundingClientRect();
      underline.classList.toggle("no-anim", !animate);
      underline.style.setProperty("--underline-x", `${rect.left - navRect.left}px`);
      underline.style.setProperty("--underline-width", `${rect.width}px`);
      underline.classList.add("is-visible");
    };

    // Snap the underline under the active link without animating. On a
    // navigation the persisted element still holds the previous page's
    // position, and sliding it across to the clicked page reads as a glitch
    // (the bar "flies in" from the old link). The user clicked a specific
    // link, so the bar should simply already be there. The slide animation is
    // reserved for hover, where it feels intentional.
    moveTo(active, false);
    // Commit the snapped position with the transition disabled (a forced
    // reflow flushes it), then re-enable transitions so hover still animates.
    // Without the reflow the position change and the class removal collapse
    // into one style recalc and the move animates anyway.
    void underline.offsetWidth;
    underline.classList.remove("no-anim");

    // Follow hover, snap back to active on leave.
    links.forEach((a) => {
      a.addEventListener("mouseenter", () => moveTo(a, true), { signal });
    });
    nav.addEventListener("mouseleave", () => moveTo(active, true), { signal });

    // Reposition on resize (widths change → line would drift).
    window.addEventListener(
      "resize",
      () => moveTo(nav.querySelector<HTMLElement>("a.active"), false),
      { signal },
    );
  }

  setupHeaderControls();
  document.addEventListener("astro:page-load", setupHeaderControls);
</script>

<style>
  header {
    margin: 0;
    padding: 0 1em;
    background-color: var(--color-bg-header);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background-color 0.3s ease;
    /* During a ClientRouter view-transition swap, the page captures old/new
       snapshots into a top-layer overlay where the normal z-index above is
       meaningless. <main> is named (transition:animate), so its group would
       paint ABOVE the unnamed root group that holds this header — for one frame
       the content snapshot flashes over the navbar (Chrome/Firefox; Safari
       skips this compositing). Giving the header its own named group lets us
       force its paint order above main's via ::view-transition-group below. */
    view-transition-name: site-header;
  }

  header::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border) 20%,
      var(--color-border) 80%,
      transparent 100%
    );
    opacity: 0.6;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
    height: 4.5rem;
    /* Anchor for the absolutely-centered nav menu. */
    position: relative;
  }
  h2 {
    margin: 0;
    font-size: 1.3em;
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: -0.02em;
    border-bottom: none;
    padding-bottom: 0;
    display: flex;
    align-items: center;
  }
  h2 a {
    text-decoration: none;
    color: var(--color-text-main);
    border: none;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    line-height: 1;
  }
  .brand:hover {
    opacity: 1;
    text-decoration: none;
  }
  .brand-logo {
    position: relative;
    display: inline-flex;
    width: 2.7rem;
    height: 2.7rem;
    flex-shrink: 0;
    /* Integral sign + "e" color: black in light mode, theme cyan in dark. */
    --brand-logo-primary: #000;
    /* Neon-glow colors per symbol. The cyan/primary glow follows the theme;
       in light mode the symbol is black, so we glow with the theme cyan
       rather than black so it actually reads as light. */
    --brand-glow-primary: #77a4f5;
    --brand-glow-secondary: #ff49ff;
  }
  /* The two color layers stack so they overlay pixel-perfectly (shared viewBox).
     The first is in normal flow to size the box; the second is absolutely
     positioned on top. */
  .brand-layer {
    display: inline-flex;
    width: 100%;
    height: 100%;
  }
  .brand-layer-secondary {
    position: absolute;
    inset: 0;
  }
  .brand-layer :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    /* An <svg> clips to its viewBox by default, which would chop the
       drop-shadow glow at the artwork's edges. Let it paint outside the
       viewport so the halo can spread. */
    overflow: visible;
  }
  :global(html[data-theme="dark"]) .brand-logo {
    --brand-logo-primary: var(--color-accent);
    --brand-glow-primary: var(--color-accent);
  }

  /* Neon-tube hover glow: each symbol emits its own color via stacked
     drop-shadows (tight bright core + softer outer halo). The filter is applied
     to each layer's <svg> ELEMENT (not its inner paths) because Safari/WebKit
     doesn't reliably render `filter` on inner SVG nodes. Splitting the mark into
     two color layers keeps the two-tone glow while staying Safari-safe. */
  .brand-layer :global(svg) {
    transition: filter 0.3s ease;
  }
  .brand:hover .brand-layer-primary :global(svg) {
    filter: drop-shadow(0 0 6px var(--brand-glow-primary))
      drop-shadow(0 0 16px var(--brand-glow-primary));
  }
  .brand:hover .brand-layer-secondary :global(svg) {
    filter: drop-shadow(0 0 6px var(--brand-glow-secondary))
      drop-shadow(0 0 16px var(--brand-glow-secondary));
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-layer :global(svg) {
      transition: none;
    }
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    /* Centered in the nav independent of the (uneven) brand/action widths on
       either side: taken out of flow and pinned to the nav's true horizontal
       center. The sliding underline positions itself against the live rects of
       these links, so it still tracks correctly. */
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    /* Glow color for nav links + underline. In light mode the accent is a dark
       navy that wouldn't read as a glow, so glow with the brighter accent
       blue; in dark mode the accent itself is bright enough. */
    --nav-glow: #77a4f5;
  }
  :global(html[data-theme="dark"]) .internal-links {
    --nav-glow: var(--color-accent);
  }
  .internal-links :global(a) {
    padding: 0.5em 0.75em;
    color: var(--color-text-main);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition:
      color 0.2s ease,
      text-shadow 0.2s ease;
  }
  /* Active link takes the accent color (the sliding underline marks it); no
     glow unless hovered. */
  .internal-links :global(a.active) {
    color: var(--color-accent);
  }
  /* Neon glow only on hover, matching the logo's accent-colored glow. */
  .internal-links :global(a:hover) {
    color: var(--color-accent);
    text-shadow:
      0 0 6px var(--nav-glow),
      0 0 14px var(--nav-glow);
  }

  /* Shared underline that slides between links. JS positions it via custom
     props; the transition makes it glide from the old link to the new one. */
  .nav-underline {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: var(--underline-width, 0);
    transform: translateX(var(--underline-x, 0));
    background-color: var(--color-accent);
    border-radius: 2px;
    box-shadow:
      0 0 6px var(--nav-glow),
      0 0 12px var(--nav-glow);
    opacity: 0;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
    pointer-events: none;
  }
  .nav-underline.is-visible {
    opacity: 1;
  }
  /* Skip the slide animation on first paint (before any nav happens) so the
     underline appears already in place rather than flying in from the left. */
  .nav-underline.no-anim {
    transition: opacity 0.2s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-underline {
      transition: opacity 0.2s ease;
    }
  }

  .dropdown {
    position: relative;
    display: inline-block;
  }
  .dropbtn {
    background-color: transparent;
    color: var(--color-text-main);
    padding: 0.5em 0.75em;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: inherit;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s ease;
    border-bottom: 2px solid transparent;
  }
  .dropdown:hover .dropbtn {
    color: var(--color-accent);
  }
  .dropdown-content {
    display: none;
    position: absolute;
    background-color: var(--color-bg-mobile-menu);
    backdrop-filter: blur(40px) saturate(150%);
    -webkit-backdrop-filter: blur(40px) saturate(150%);
    min-width: 120px;
    box-shadow: 0px 8px 16px 0px rgba(0, 0, 0, 0.2);
    z-index: 1;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-header-border);
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
  }
  .dropdown-content :global(a) {
    color: var(--color-text-main);
    padding: 12px 16px;
    text-decoration: none;
    display: block;
    border-bottom: none;
  }
  .dropdown-content :global(a:hover) {
    background-color: var(--color-bg-offset);
  }
  .dropdown:hover .dropdown-content,
  .dropdown:focus-within .dropdown-content {
    display: block;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    /* Glow color for the action icons, mirroring the nav links. Light-mode
       accent is too dark to read as a glow, so use the brighter blue there. */
    --nav-glow: #77a4f5;
  }
  :global(html[data-theme="dark"]) .header-actions {
    --nav-glow: var(--color-accent);
  }

  .search-toggle,
  #theme-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-main);
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }
  .search-toggle:hover,
  #theme-toggle:hover {
    background-color: var(--color-bg-offset);
    color: var(--color-accent);
  }

  .github-link {
    background: transparent;
    border: none;
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-main);
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .github-link:hover {
    background-color: var(--color-bg-offset);
    color: var(--color-accent);
  }

  /* Neon glow on the action icons on hover. The SVGs use currentColor, so the
     glow is a drop-shadow filter on the icon itself (text-shadow wouldn't
     affect the strokes). */
  .header-actions :global(svg) {
    transition: filter 0.2s ease;
  }
  .github-link:hover :global(svg),
  .search-toggle:hover :global(svg),
  #theme-toggle:hover :global(svg) {
    filter:
      drop-shadow(0 0 5px var(--nav-glow)) drop-shadow(0 0 12px var(--nav-glow));
  }

  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.25rem;
  }
  .mobile-menu-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-muted);
    padding-left: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  #menu-toggle {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-main);
  }

  .mobile-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 1rem;
    width: fit-content;
    min-width: 180px;
    background-color: var(--color-bg-mobile-menu);
    backdrop-filter: blur(40px) saturate(150%);
    -webkit-backdrop-filter: blur(40px) saturate(150%);
    border: 1px solid var(--color-header-border);
    border-radius: 12px;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.12),
      0 2px 8px rgba(0, 0, 0, 0.08);
    z-index: 200;
    animation: menuFadeIn 0.2s ease;
  }
  @keyframes menuFadeIn {
    from {
      opacity: 0;
      transform: translateY(-8px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .mobile-menu a {
    padding: 0.5rem 0.875rem;
    text-decoration: none;
    color: var(--color-text-main);
    font-weight: 500;
    font-size: 0.9rem;
    border-radius: 8px;
    transition:
      background-color 0.2s,
      color 0.2s;
  }
  .mobile-menu a:hover {
    background-color: var(--color-bg-offset);
    color: var(--color-accent);
  }
  .mobile-menu-section {
