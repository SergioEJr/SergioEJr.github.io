---
import authorsData from '../data/authors.json';
import { normalizeAuthorAvatar } from '../utils/authors';

interface Props {
  nameOrSlug: string;
}

const { nameOrSlug } = Astro.props;

const normalize = (s: string) => {
    if (!s) return "";
    return s.toLowerCase().replace(/[^a-z0-9]/g, '');
};

const target = normalize(nameOrSlug);

let author = authorsData.find(a => a.id === nameOrSlug);

if (!author && target) {
    author = authorsData.find(a => {
        const dbName = normalize(a.name);
        return dbName.includes(target) || target.includes(dbName);
    });
}

if (author?.avatar) {
    author = {
        ...author,
        avatar: normalizeAuthorAvatar(author.avatar),
    };
}

// The site owner is emphasized (bold + underline); every other author renders
// plain, even when their profile card is clickable.
const OWNER_ID = 'sergio-eraso';
const isOwner = author?.id === OWNER_ID;
---

{author ? (
    <span
        class:list={['author-link', 'author-modal-trigger', { 'author-owner': isOwner }]}
        data-member={JSON.stringify(author)}
        style="cursor: pointer;"
    >
        {author.name}
    </span>
) : (
    <span>{nameOrSlug.replace(/[{}]/g, '')}</span>
)}
