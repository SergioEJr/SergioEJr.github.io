---
interface Props {
  count?: number;
  class?: string;
}
const { count = 46, class: className = "" } = Astro.props;
---

<canvas
  class:list={["journal-glow-field", className]}
  data-count={count}
  aria-hidden="true"></canvas>

<style>
  .journal-glow-field {
    position: absolute;
    /* The drawing band bleeds UP toward the navbar and DOWN past .j-head to the
       bottom of the filter bar. left/top are set here; width/height are measured
       and set in JS (resize) so the canvas reaches the filter bar's bottom edge.
       The sticky filter bar (z-index 30) paints over the bleed. */
    left: 0;
    top: 0;
    pointer-events: none;
    z-index: 0;
    /* Fade driven by the IntersectionObserver. */
    opacity: 1;
    transition: opacity 0.45s ease;
    /* Soft bottom fade so the field dissolves into the filter bar with no abrupt
       seam. Done as a CSS mask (not a per-frame canvas wipe) so it's identical at
       every width — including the taller mobile filter bar. The last 36px of the
       canvas ramp from opaque to transparent. */
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 calc(100% - 36px),
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      #000 calc(100% - 36px),
      transparent 100%
    );
  }
</style>

<script>
  // Reference header area (≈ content width × header height) used to area-scale
  // the particle count so the field isn't sparse on tall mobile headers.
  const REF_AREA = 760 * 210;
  const MIN_N = 18;
  const MAX_N = 80;

  function initJournalGlowField() {
    const canvases = Array.from(
      document.querySelectorAll<HTMLCanvasElement>(".journal-glow-field"),
    );
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    for (const canvas of canvases) {
      if ((canvas as any).__glowBound) continue;
      (canvas as any).__glowBound = true;

      const ctx = canvas.getContext("2d");
      if (!ctx) continue;
      const parent = canvas.parentElement!;
      const DPR = Math.min(window.devicePixelRatio || 1, 2);
      const baseCount = parseInt(canvas.dataset.count || "46", 10);

      // Look B (Balanced) tuning, from the approved visual demo.
      const LOOK = {
        // Soft halo radius AROUND the eyebrow pill (px), independent of canvas
        // size. Kept small relative to the eyebrow width so the glow reads as a
        // horizontal pill, not a big circle. The particle-lighting reach is
        // separate (proximity uses the canvas diagonal).
        glowR: 95,
        glowAlpha: 0.18, // peak glow opacity at the core
        lightAlpha: 0.75, // proximity brightening weight
        shade: 0.55, // directional highlight/shadow weight
        baseAlpha: 0.42, // ambient particle alpha away from light
        lightReach: 0.55, // particle proximity reach as fraction of canvas diagonal
      };

      // Light source state. The light is pinned to the eyebrow ("<FILTER> · N
      // PIECES") — a stable anchor near the top of the header. It's PILL-shaped:
      // a horizontal capsule matching the eyebrow's footprint, so the glow looks
      // like it emanates from the text itself rather than from a point behind it.
      // hx/hy are the capsule's half-width / half-height. Position barely moves
      // between filters (only the label changes); the COLOR is what animates.
      const light = { x: 0, y: 0, hx: 40, hy: 8 };

      // Measure the eyebrow's center + half-extents, in canvas-local coordinates.
      function measureLight(): { x: number; y: number; hx: number; hy: number } {
        const eyebrow = document.querySelector(".j-eyebrow");
        const cr = canvas.getBoundingClientRect();
        if (!eyebrow) return { x: W / 2, y: H * 0.35, hx: 40, hy: 8 };
        const er = (eyebrow as HTMLElement).getBoundingClientRect();
        return {
          x: er.left + er.width / 2 - cr.left,
          y: er.top + er.height / 2 - cr.top,
          hx: er.width / 2,
          hy: er.height / 2,
        };
      }
      function recomputeTarget() {
        const m = measureLight();
        targetX = m.x;
        light.y = m.y;
        light.hx = m.hx;
        light.hy = m.hy;
      }
      let targetX = 0;

      // Resolve --cat-color (may be a hex like #3b82f6 or var(--color-accent))
      // to concrete RGB. `targetRGB` is the active filter's color; the displayed
      // `lightRGB` eases toward it in tick() so color and position arrive together
      // (without this, the color snaps instantly while the light is still gliding).
      let lastColorStr = "";
      let lightRGB: [number, number, number] = [96, 165, 250];
      let targetRGB: [number, number, number] = [96, 165, 250];
      const probe = document.createElement("span");
      probe.style.display = "none";
      function resolveCatColor() {
        const journal = document.getElementById("journal");
        const raw = journal
          ? getComputedStyle(journal).getPropertyValue("--cat-color").trim()
          : "";
        if (raw === lastColorStr) return;
        lastColorStr = raw;
        // Let the browser resolve var()/hex/named to rgb() via computed style.
        if (!probe.isConnected) document.body.appendChild(probe);
        probe.style.color = raw || "var(--color-accent)";
        const rgb = getComputedStyle(probe).color; // "rgb(r, g, b)"
        const m = rgb.match(/(\d+),\s*(\d+),\s*(\d+)/);
        if (m) targetRGB = [+m[1], +m[2], +m[3]];
      }

      let W = 0,
        H = 0;
      const parts: {
        x: number;
        y: number;
        vx: number;
        vy: number;
        r: number;
        ph: number;
      }[] = [];

      // Distance to bleed UP from .j-head's top toward the navbar bottom (4.5rem
      // ≈ 72px). The band fills from just under the navbar down to the TOP of the
      // filter bar (the bar frosts over anything behind it, so drawing under it
      // only creates a seam). A short bottom fade hides the meeting edge.
      const NAVBAR_BOTTOM = 72;

      function resize() {
        const rect = parent.getBoundingClientRect(); // .j-head box
        const bar = document.querySelector(".j-filters-bar");
        const barRect = bar ? bar.getBoundingClientRect() : null;

        // Vertical band: from just under the navbar down to the filter bar's TOP.
        const bleedUp = Math.max(0, rect.top - NAVBAR_BOTTOM);
        const top = rect.top - bleedUp;
        const bottom = barRect ? barRect.top : rect.bottom;

        // Horizontal: bleed full viewport width (edge to edge), not just the
        // content column, so the lighting fills the whole header band.
        const vw = document.documentElement.clientWidth;
        W = vw;
        H = Math.max(1, bottom - top);

        // Canvas is absolutely positioned inside .j-head (rect.left from viewport
        // edge), so shift left by rect.left to reach the viewport's left edge.
        canvas.style.left = `${-rect.left}px`;
        canvas.style.top = `${-bleedUp}px`;
        canvas.style.width = `${W}px`;
        canvas.style.height = `${H}px`;
        canvas.width = Math.max(1, Math.floor(W * DPR));
        canvas.height = Math.max(1, Math.floor(H * DPR));
        ctx!.setTransform(DPR, 0, 0, DPR, 0, 0);

        // Light is pinned to the eyebrow near the top of the band.
        recomputeTarget();
        if (light.x === 0) light.x = targetX;
      }

      function particleCount() {
        const n = Math.round((baseCount * (W * H)) / REF_AREA);
        return Math.max(MIN_N, Math.min(MAX_N, n));
      }

      function seed() {
        parts.length = 0;
        const N = particleCount();
        for (let i = 0; i < N; i++) {
          parts.push({
            x: Math.random() * W,
            y: Math.random() * H,
            vx: (Math.random() - 0.5) * 0.15,
            vy: (Math.random() - 0.5) * 0.15,
            r: 0.8 + Math.random() * 1.4,
            ph: Math.random() * Math.PI * 2,
          });
        }
      }

      function draw(time = 0) {
        resolveCatColor();
        const r = Math.round(lightRGB[0]);
        const g = Math.round(lightRGB[1]);
        const b = Math.round(lightRGB[2]);
        const lx = light.x;
        const ly = light.y;

        // Theme-aware treatment. On DARK the field is additive-ish: a translucent
        // colored glow plus particles that brighten toward white near the light.
        // On LIGHT that reads as gray haze on white, so we boost glow saturation
        // and DARKEN particles toward a deeper accent (so they show on white).
        const dark =
          document.documentElement.getAttribute("data-theme") === "dark";
        const glowK = dark ? 1 : 1.6; // light mode needs a stronger glow to read

        ctx!.clearRect(0, 0, W, H);

        // Capsule light: a horizontal pill matching the eyebrow's footprint, so
        // the glow looks like it comes from the text. The capsule is the segment
        // [lx-hx, lx+hx] at y=ly; the glow falls off radially from that segment
        // with a SMALL halo radius (glowR) so the elongation reads as a pill.
        const hx = light.hx;
        const gr = LOOK.glowR; // small, fixed halo — NOT the canvas size
        const gA = LOOK.glowAlpha * glowK;

        // Render the pill by scaling X so a small radial gradient stretches into a
        // capsule whose flat middle spans the eyebrow width (2*hx). With gr small
        // relative to hx, sx is large and the glow is clearly pill-shaped.
        const sx = (gr + hx) / gr;
        ctx!.save();
        ctx!.translate(lx, ly);
        ctx!.scale(sx, 1);
        const grad = ctx!.createRadialGradient(0, 0, 0, 0, 0, gr);
        grad.addColorStop(0, `rgba(${r},${g},${b},${gA})`);
        grad.addColorStop(0.45, `rgba(${r},${g},${b},${gA * 0.45})`);
        grad.addColorStop(1, `rgba(${r},${g},${b},0)`);
        ctx!.fillStyle = grad;
        // Fill a generous rect in the scaled space (covers the whole canvas).
        const halfW = W / sx + hx;
        ctx!.fillRect(-halfW, -H, halfW * 2, H * 2);
        ctx!.restore();

        // Particles lit by distance to the capsule SEGMENT (not a point), so the
        // whole text line acts as the source.
        const maxd = Math.hypot(W, H);
        for (const p of parts) {
          // Nearest point on the horizontal segment [lx-hx, lx+hx] at y=ly.
          const nx = Math.max(lx - hx, Math.min(lx + hx, p.x));
          const ny = ly;
          // Vector from that nearest point to the particle → distance + direction.
          const vx = p.x - nx;
          const vy = p.y - ny;
          const dist = Math.hypot(vx, vy) || 1;
          const prox = Math.max(0, 1 - dist / (maxd * LOOK.lightReach)); // brighter near light
          // Directional shading: brighter on the side facing the light segment.
          const facing = (-vx / dist) * 0.6 + (-vy / dist) * 0.4; // -1..1
          const dirLit = 0.5 + 0.5 * facing; // 0..1
          const twinkle = 0.85 + 0.15 * Math.sin(time * 1.5 + p.ph);

          const lit =
            LOOK.baseAlpha +
            LOOK.lightAlpha * prox * prox +
            LOOK.shade * prox * (dirLit - 0.5);
          // Light mode needs a higher alpha floor so particles register on white.
          const a = Math.max(dark ? 0.04 : 0.12, Math.min(1, lit * twinkle));

          const heat = prox * prox;
          let cr: number, cg: number, cb: number;
          if (dark) {
            // Hot core: tint toward white near the light, accent farther out.
            cr = Math.round(r + (255 - r) * heat * 0.7);
            cg = Math.round(g + (255 - g) * heat * 0.7);
            cb = Math.round(b + (255 - b) * heat * 0.7);
          } else {
            // On white, brightening toward white makes particles vanish. Instead
            // DARKEN toward a deeper accent near the core so they read as lit.
            cr = Math.round(r * (1 - heat * 0.45));
            cg = Math.round(g * (1 - heat * 0.45));
            cb = Math.round(b * (1 - heat * 0.45));
          }

          ctx!.globalAlpha = a;
          ctx!.fillStyle = `rgb(${cr},${cg},${cb})`;
          ctx!.beginPath();
          ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx!.fill();
        }
        ctx!.globalAlpha = 1;
        // Bottom fade is handled by a CSS mask on the canvas element (see <style>),
        // which is layout-independent and consistent across all widths — unlike a
        // per-frame canvas wipe, which drifted on the taller mobile filter bar.
      }

      let t0 = 0;
      function tick(now: number) {
        if (!t0) t0 = now;
        const time = (now - t0) / 1000;
        for (const p of parts) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0) p.x += W;
          if (p.x > W) p.x -= W;
          if (p.y < 0) p.y += H;
          if (p.y > H) p.y -= H;
        }
        // Position glides slowly (the light visibly travels to the new pill).
        light.x += (targetX - light.x) * 0.12;
        // Color transitions on its OWN, faster ease — decoupled from position so
        // the hue changes smoothly and promptly instead of looking "paused" while
        // the light is still mid-glide.
        const cEase = 0.28;
        lightRGB[0] += (targetRGB[0] - lightRGB[0]) * cEase;
        lightRGB[1] += (targetRGB[1] - lightRGB[1]) * cEase;
        lightRGB[2] += (targetRGB[2] - lightRGB[2]) * cEase;
        draw(time);
        raf = requestAnimationFrame(tick);
      }

      let raf = 0;
      resize();
      seed();
      // Seed the displayed color from the active filter so the first paint is the
      // right color (no blue→accent glide on load) and the reduced-motion frame
      // is correct.
      resolveCatColor();
      lightRGB = [targetRGB[0], targetRGB[1], targetRGB[2]];
      if (reduce) {
        recomputeTarget();
        light.x = targetX;
        draw();
      } else {
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              canvas.style.opacity = "1";
              recomputeTarget(); // re-measure in case layout shifted while away
              if (!raf) raf = requestAnimationFrame(tick);
            } else {
              canvas.style.opacity = "0";
              cancelAnimationFrame(raf);
              raf = 0;
            }
          }
        });
        io.observe(parent); // parent is .j-head
      }
      window.addEventListener("resize", () => {
        resize();
        seed();
        recomputeTarget();
        if (reduce) {
          light.x = targetX;
          draw();
        }
      });

      // Recompute the light target when the active filter changes by any means:
      // a pill click, a URL-hash filter change (or Back), or a layout reflow.
      document.querySelectorAll(".j-filter").forEach((btn) => {
        btn.addEventListener("click", () => {
          // The filter script toggles .active synchronously on click; measure
          // on the next frame so the new active element + its rect are settled.
          requestAnimationFrame(recomputeTarget);
        });
      });
      window.addEventListener("hashchange", () =>
        requestAnimationFrame(recomputeTarget),
      );
    }
  }

  initJournalGlowField();
  document.addEventListener("astro:page-load", initJournalGlowField);
</script>
