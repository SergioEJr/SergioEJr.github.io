---
// A margin/side note for articles (use in .mdx posts).
//
//   import SideNote from '../../components/SideNote.astro';
//   Some claim in the text.<SideNote>The aside floats in the right margin.</SideNote>
//
// Optional `label` overrides the "Note" heading:
//   <SideNote label="Aside">…</SideNote>
//
// On wide screens it floats into the right gutter, near where it appears in the
// text. On narrow screens it collapses to an indented inline block under the
// paragraph so nothing is lost on mobile.
//
// On wide screens the right gutter is shared with the sticky Table of Contents,
// so a small script fades each note out as it scrolls up into the ToC's band,
// keeping things from overlapping awkwardly.

interface Props {
  label?: string;
}

const { label = "Note" } = Astro.props;
---

<span class="sidenote__body" data-sidenote>
  <span class="sidenote__head">
    <svg
      class="sidenote__icon"
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12 20h9"></path>
      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
    </svg>
    <span class="sidenote__label">{label}</span>
  </span>
  <span class="sidenote__content">
    <slot />
  </span>
</span>

<style>
  .sidenote__body {
    display: block;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    text-align: left;
    /* Subtle card: faint accent-tinted background + left border so it pops a
       little without being loud. */
    background: color-mix(in srgb, var(--color-accent) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);
    border-left: 3px solid var(--color-accent);
    border-radius: 8px;
    padding: 0.65rem 0.8rem;
    /* Narrow screens (default): block aside under the paragraph. */
    margin: 0.7rem 0 0.95rem;
  }

  .sidenote__head {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.4rem;
    color: var(--color-accent);
  }
  .sidenote__icon {
    flex-shrink: 0;
  }
  .sidenote__label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }
  .sidenote__content {
    display: block;
  }

  /* Wide screens: float into the right gutter beside the 760px prose column.
     Only do this at >=1200px, where the gutter is actually wide enough for the
     negative margin — below that the -margin would push past the viewport edge,
     causing horizontal overflow (which also breaks the sticky navbar). */
  @media (min-width: 1200px) {
    .sidenote__body {
      float: right;
      clear: right;
      width: 190px;
      margin: 0 -222px 1rem 0; /* -(gutter width) so it sits outside the column */
      transition: opacity 0.2s ease;
    }
  }
</style>

<script is:inline data-astro-rerun>
  // Fade a side note as it scrolls up toward the ToC. Opacity reaches 0 exactly
  // when the note's TOP edge meets the ToC's BOTTOM edge — so the note is gone the
  // instant it would start overlapping the ToC. It fades over the GAP px just below
  // the ToC bottom; everything is measured live, so it adapts to ToC height and
  // screen size.
  // (Inline so it's reliably emitted even when this component is used in MDX.)
  (function () {
    var GAP = 90; // px below the ToC bottom over which the note fades out
    var ticking = false;
    var notes = [];
    var tocInner = null;
    var wide;

    function update() {
      ticking = false;
      if (!tocInner || !wide.matches) {
        for (var i = 0; i < notes.length; i++) notes[i].style.opacity = "";
        return;
      }
      // The visible ToC box, measured every frame (it's sticky, so it moves).
      var toc = tocInner.getBoundingClientRect();
      for (var j = 0; j < notes.length; j++) {
        var note = notes[j].getBoundingClientRect();
        // How far the note's TOP sits below the ToC's BOTTOM edge. Large positive =
        // note is well clear below the ToC (opacity 1). Opacity reaches 0 exactly
        // when the note's top reaches the ToC bottom, so the note is gone before it
        // overlaps the ToC. Fade happens over the GAP px just below the ToC bottom.
        var distance = note.top - toc.bottom;
        var opacity = distance / GAP;
        if (opacity < 0) opacity = 0;
        if (opacity > 1) opacity = 1;
        notes[j].style.opacity = String(opacity);
      }
    }
    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }

    function setup() {
      notes = Array.prototype.slice.call(
        document.querySelectorAll("[data-sidenote]"),
      );
      if (notes.length === 0) return;
      // Only fade when a sticky ToC actually shares the right gutter: rendered
      // (pages with a ToC) and visible (>=1200px). Otherwise notes overlap nothing.
      tocInner = document.querySelector(".toc-inner");
      wide = window.matchMedia("(min-width: 1200px)");
      update();
    }

    if (!window.__sidenoteFadeBound) {
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });
      window.__sidenoteFadeBound = true;
    }
    setup();
    document.addEventListener("astro:page-load", setup);
  })();
</script>
