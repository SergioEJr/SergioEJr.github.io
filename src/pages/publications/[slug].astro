---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const research = await getCollection('research');
	return research.map((entry) => ({
		params: { slug: entry.id },
		props: entry,
	}));
}
type Props = CollectionEntry<'research'>;

const entry = Astro.props;
const { Content, headings } = await render(entry);
const { title, abstract, date, paper, poster } = entry.data;
import { url } from '../../utils/paths';

// Meta/SEO description: use the abstract if present, else the title.
const metaDescription = abstract ?? title;
---

<BlogPost
	title={title}
	description={metaDescription}
	pubDate={date}
	id={entry.id}
	headings={headings}
	toc={headings.length > 1}
	noHero={true}
>
	{(paper || poster) && (
		<div class="research-links">
			{paper && (
				<a class="btn" href={paper} target="_blank" rel="noopener noreferrer" data-umami-event="paper-click" data-umami-event-title={title}>Paper ↗</a>
			)}
			{poster && (
				<a class="btn btn-outline" href={url(poster)} target="_blank" rel="noopener noreferrer" data-umami-event="poster-click" data-umami-event-title={title}>Poster ↗</a>
			)}
		</div>
	)}
	<Content />
</BlogPost>

<style>
	.research-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.bibtex summary {
		cursor: pointer;
		font-weight: 600;
		color: var(--color-accent);
	}
	.bibtex pre {
		margin-top: 0.75rem;
		padding: 1rem;
		background: var(--color-bg-offset);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		overflow-x: auto;
		font-size: 0.85rem;
	}
</style>
