---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { BLOG_CATEGORY_COLORS, BLOG_CATEGORY_LABELS } from '../../utils/categories';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	// Pointer posts (externalUrl / linkTo) link straight to a target, and
	// link-less update posts (noLink) have no destination at all — neither
	// renders its own detail page.
	return posts
		.filter((post) => !post.data.externalUrl && !post.data.linkTo && !post.data.noLink)
		.map((post) => ({
			params: { slug: post.id },
			props: post,
		}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);

const categoryBadges = [{
	label: BLOG_CATEGORY_LABELS[post.data.category] ?? post.data.category,
	color: BLOG_CATEGORY_COLORS[post.data.category] ?? 'var(--color-accent)',
}];
---

<BlogPost {...post.data} id={post.id} headings={headings} categoryBadges={categoryBadges}>
	<Content />
</BlogPost>
