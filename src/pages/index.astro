---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import { url } from "../utils/paths";
import { pageFade } from "../utils/pageTransition";
import { getPublishedPosts } from "../utils/posts";

const posts = (await getPublishedPosts())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allResearch = (await getCollection("research")).sort(
  (a, b) =>
    b.data.date.valueOf() - a.data.date.valueOf() || a.id.localeCompare(b.id),
);
const selectedResearch = (
  allResearch.filter((r) => r.data.selected).length > 0
    ? allResearch.filter((r) => r.data.selected)
    : allResearch
).slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        display: flex;
        align-items: center;
        gap: 4rem;
        padding: 4rem 0;
        margin-bottom: 2rem;
      }
      .hero-content {
        flex: 3;
      }
      .hero-image {
        flex: 2;
        text-align: center;
        position: relative;
        /* Perspective for the subtle tilt of the portrait link inside. */
        perspective: 900px;
      }
      .hero-image-link {
        display: inline-block;
        position: relative;
        border-radius: 50%;
        /* --rx/--ry are driven by JS (lerped); default = flat & resting.
           --mx/--my track the cursor (%), --glare is the live 0→1 opacity. */
        --rx: 0deg;
        --ry: 0deg;
        --mx: 50%;
        --my: 50%;
        --glare: 0;
        transform: rotateX(var(--rx)) rotateY(var(--ry));
        transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
        will-change: transform;
      }
      /* Very subtle glare: a soft white light that follows the cursor. Clipped
         to the circular portrait and inset slightly to stay off the white ring.
         --glare-strength caps how bright it gets. */
      .hero-image-link::after {
        content: "";
        position: absolute;
        inset: 6px; /* matches the img border so the glare stays on the photo */
        border-radius: 50%;
        pointer-events: none;
        opacity: calc(var(--glare) * var(--glare-strength, 0.28));
        background: radial-gradient(
          circle at var(--mx) var(--my),
          rgba(255, 255, 255, 0.9),
          transparent 45%
        );
        mix-blend-mode: soft-light;
      }
      /* Cancel the global a:hover dim/underline — over the photo it reads as a
         grayish wash. The tilt is the only hover affordance we want here. */
      .hero-image-link:hover {
        opacity: 1;
        text-decoration: none;
      }
      .hero-image img {
        display: block;
        width: 280px;
        height: 280px;
        object-fit: cover;
        border-radius: 50%;
        border: 6px solid var(--color-bg);
        box-shadow:
          0 0 0 1px var(--color-border),
          0 12px 28px rgba(0, 0, 0, 0.55);
      }

      .pub-mini-item {
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
      }
      .pub-mini-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
      }
      .pub-title {
        font-weight: 700;
        color: var(--color-text-main);
        display: block;
        margin-bottom: 0.25rem;
        font-family: var(--font-serif);
        font-size: 1.1rem;
      }
      .pub-meta {
        font-size: 0.9rem;
        color: var(--color-text-muted);
      }

      .hero-buttons {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      @media (max-width: 768px) {
        .hero {
          flex-direction: column-reverse;
          text-align: center;
          padding: 2rem 0;
          gap: 2rem;
        }
        .hero-image img {
          width: 200px;
          height: 200px;
        }
        .hero-buttons {
          justify-content: center;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main transition:animate={pageFade}>
      <section class="hero">
        <div class="hero-content">
          <h1 style="margin-bottom: 0.5rem; font-size: 3rem;">Sergio Eraso</h1>
          <h2
            style="font-weight: 400; color: var(--color-text-muted); margin-bottom: 1.5rem; font-family: var(--font-sans); text-transform: uppercase; letter-spacing: 0.05em; font-size: 1rem; border-bottom: none; padding-bottom: 0; display: block; margin-top: 0;"
          >
            PhD Student in Physics<br />
            Massachusetts Institute of Technology
          </h2>
          <p style="font-size: 1.1rem; line-height: 1.7; margin-bottom: 2rem;">
            I'm a physicist working on <strong
              >nonequilibrium statistical physics and biophysics</strong
            >. I build models, simulations, and tools to understand how simple
            local rules produce predictable large-scale behavior in complex
            systems — and I'm increasingly applying that toolkit to problems
            beyond academia.
          </p>
          <div class="hero-buttons">
            <a href={url("/publications")} class="btn">View Research</a>
            <a href={url("/projects")} class="btn btn-outline">Projects</a>
          </div>
        </div>
        <div class="hero-image">
          <a
            href={url("/about")}
            class="hero-image-link"
            aria-label="About Sergio Eraso"
          >
            <img
              src={url("/about/profile.jpeg")}
              width={280}
              height={280}
              alt="Sergio Eraso"
              fetchpriority="high"
              decoding="async"
            />
          </a>
        </div>
      </section>

      <hr style="margin: 3rem 0; border-top: 1px solid var(--color-border);" />

      <div class="grid-2" style="gap: 4rem; margin-top: 0;">
        <section>
          <h2 style="margin-top: 0;">Selected Research</h2>
          <div class="publication-list">
            {
              selectedResearch.length > 0 ? (
                selectedResearch.map((entry) => (
                  <div class="pub-mini-item">
                    <a
                      class="pub-title"
                      href={url(`/publications/${entry.id}/`)}
                      style="display: block;"
                    >
                      {entry.data.title}
                    </a>
                    <div class="pub-meta">
                      <span style="font-style: italic; color: var(--color-accent);">
                        {entry.data.venue || "In preparation"}
                      </span>
                      <span>, {entry.data.date.getUTCFullYear()}</span>
                    </div>
                  </div>
                ))
              ) : (
                <p>No research entries yet.</p>
              )
            }
          </div>
          <div style="margin-top: 1.5rem;">
            <a href={url("/publications")} style="font-weight: 600;"
              >View all research &rarr;</a
            >
          </div>
        </section>

        <section>
          <h2 style="margin-top: 0;">Latest Posts</h2>
          <ul style="list-style: none; padding: 0;">
            {
              posts.map((post) => (
                <li style="margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px dashed var(--color-border);">
                  <a
                    href={url(`/blog/${post.id}/`)}
                    style="display: block; font-family: var(--font-serif); font-size: 1.1rem; font-weight: 600; color: var(--color-text-main); margin-bottom: 0.25rem;"
                  >
                    {post.data.title}
                  </a>
                  <small style="color: var(--color-text-muted); text-transform: uppercase; font-size: 0.8rem;">
                    {post.data.pubDate.toLocaleDateString("en-us", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                      timeZone: "UTC",
                    })}
                  </small>
                </li>
              ))
            }
          </ul>
          <a href={url("/blog")} style="font-weight: 600;">View Blog &rarr;</a>
        </section>
      </div>
    </main>
    <Footer />

    <script is:inline>
      function initHeroTilt() {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches)
          return;
        if (!window.matchMedia("(hover: hover)").matches) return;

        const link = document.querySelector(".hero-image-link");
        if (!link) return;
        if (link._tiltCleanup) link._tiltCleanup();

        // Extremely subtle: a few degrees of tilt that follows the cursor.
        const MAX_TILT = 4; // degrees
        const EASE = 0.12; // lerp factor/frame → smooth ramp & settle

        let rx = 0,
          ry = 0,
          mx = 50,
          my = 50,
          glare = 0,
          trx = 0,
          try_ = 0,
          tmx = 50,
          tmy = 50,
          tglare = 0,
          raf = null;

        function tick() {
          raf = null;
          rx += (trx - rx) * EASE;
          ry += (try_ - ry) * EASE;
          mx += (tmx - mx) * EASE;
          my += (tmy - my) * EASE;
          glare += (tglare - glare) * EASE;
          link.style.setProperty("--rx", rx.toFixed(3) + "deg");
          link.style.setProperty("--ry", ry.toFixed(3) + "deg");
          link.style.setProperty("--mx", mx.toFixed(2) + "%");
          link.style.setProperty("--my", my.toFixed(2) + "%");
          link.style.setProperty("--glare", glare.toFixed(3));
          if (
            Math.abs(trx - rx) > 0.01 ||
            Math.abs(try_ - ry) > 0.01 ||
            Math.abs(tmx - mx) > 0.05 ||
            Math.abs(tmy - my) > 0.05 ||
            Math.abs(tglare - glare) > 0.002
          )
            schedule();
        }
        function schedule() {
          if (raf == null) raf = requestAnimationFrame(tick);
        }

        // Disable the CSS transition while tracking; the lerp smooths it. On
        // leave we restore it so the portrait eases back to flat.
        function onMove(e) {
          const r = link.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width; // 0..1
          const py = (e.clientY - r.top) / r.height; // 0..1
          link.style.transition = "none";
          try_ = (px - 0.5) * 2 * MAX_TILT; // rotateY: left→right
          trx = -(py - 0.5) * 2 * MAX_TILT; // rotateX: top→back
          tmx = px * 100;
          tmy = py * 100;
          tglare = 1;
          schedule();
        }
        function onLeave() {
          link.style.transition = "";
          trx = 0;
          try_ = 0;
          tglare = 0;
          schedule();
        }

        link.addEventListener("pointermove", onMove);
        link.addEventListener("pointerleave", onLeave);
        link._tiltCleanup = () => {
          link.removeEventListener("pointermove", onMove);
          link.removeEventListener("pointerleave", onLeave);
          if (raf != null) cancelAnimationFrame(raf);
          delete link._tiltCleanup;
        };
      }

      initHeroTilt();
      document.addEventListener("astro:page-load", initHeroTilt);
    </script>
  </body>
</html>
