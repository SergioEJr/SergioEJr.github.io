---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSim from "../components/HeroSim.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import { url } from "../utils/paths";
import { pageFade } from "../utils/pageTransition";
import { getPublishedPosts } from "../utils/posts";

const posts = (await getPublishedPosts())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allResearch = (await getCollection("research")).sort(
  (a, b) =>
    b.data.date.valueOf() - a.data.date.valueOf() || a.id.localeCompare(b.id),
);
const selectedResearch = (
  allResearch.filter((r) => r.data.selected).length > 0
    ? allResearch.filter((r) => r.data.selected)
    : allResearch
).slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script is:inline>
      (() => {
        // Play the intro on a FULL page load (fresh visit, hard refresh, or
        // opening the site in a new tab) — but NOT when the user navigates back
        // to home via client-side routing (ClientRouter swap), since that's not
        // a "real" arrival. This inline script in <head> only executes on a true
        // document parse; ClientRouter swaps re-run scripts via astro:page-load,
        // not by re-parsing <head>, so the window flag below distinguishes them:
        // it's undefined on a fresh document and set once the intro has fired.
        const root = document.documentElement;
        try {
          if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
          if (window.__homeIntroPlayed) return; // already played this session
          window.__homeIntroPlayed = true;
          root.setAttribute("data-home-intro", "pending");
        } catch {}
      })();
    </script>
    <style>
      /* ============================================================
         PINNED-SCRUB HERO
         Two stacked layers (sim + card) inside a sticky stage. A tall spacer
         section gives the scroll distance; JS writes --hero-progress (0..1) onto
         .hero-scroll as you scroll through it, and the layers crossfade. Only
         one is ever visible. --header-h matches the sticky nav height.
         ============================================================ */
      .hero-scroll {
        --header-h: 4.5rem;
        /* Scroll distance for the crossfade. Kept short so the swap is snappy —
           a small flick carries you most of the way through the sim→card fade. */
        --hero-travel: 70svh;
        --hero-progress: 0;
        position: relative;
        height: calc(100svh - var(--header-h) + var(--hero-travel));
        /* Visible overflow so HeroSim's full-bleed canvas/grid feather past the
           content column (mobile re-clips below). */
        overflow-x: visible;
      }
      :global(html),
      :global(body) {
        overflow-x: clip;
      }
      :global(html[data-home-intro]) {
        /* Lock the vertical axis during the intro but KEEP the scrollbar track
           (overflow-y stays `scroll` from the html rule), so the page width never
           changes when the intro ends. We block actual scrolling by pinning the
           scroll position via JS (see initHomeIntro), not by hiding overflow —
           hiding it would remove the track and shift the layout. Horizontal is
           clipped so the full-bleed hero can't cause a sideways scrollbar. */
        overflow-x: clip;
        /* ---- Intro timeline knobs ----
           Phase 1  navbar fades in       [0 .. NAV_FADE]
           Phase 2  navbar neon flicker    [NAV_FADE .. +GLOW]   (in series w/ P1)
           Phase 3  simulation fades+flicks[SIM_AT .. +SIM]      (INDEPENDENT —
                    may start any time, including mid-Phase-2; see --intro-sim-at)
           The JS removes data-home-intro after the LATEST phase completes. */
        --intro-nav-fade: 1.1s; /* phase 1: nav fade-in (slow + dramatic) */
        --intro-glow-dur: 1.3s; /* phase 2: nav flicker (after fade-in) */
        --intro-sim-dur: 0.7s; /* phase 3: sim grid+canvas flicker-in */
        /* Phase 2 starts shortly BEFORE the fade fully finishes (the nav is
           already mostly visible by then), trimming the dead gap between the
           fade-in and the flicker. Lower the offset to overlap more. */
        --intro-glow-at: calc(var(--intro-nav-fade) - 0.35s);
        /* --intro-sim-at: WHEN the simulation phase begins, as an ABSOLUTE time
           from page load. It no longer has to wait for Phase 2 to finish — set it
           to whatever you like and the sim (gas fade + name flicker) will start
           there, even mid-Phase-2. The gas fade-in (CSS) and the name-activation
           flicker (HeroSim reads this same var) both key off it, so they stay in
           sync. The default below = start right when the nav flicker begins
           (overlapping all of Phase 2); raise it to delay, lower it to overlap
           earlier. Examples:
             var(--intro-glow-at)                         → starts with Phase 2
             calc(var(--intro-glow-at) + 0.65s)           → mid Phase 2
             calc(var(--intro-nav-fade) + var(--intro-glow-dur)) → after Phase 2 */
        --intro-sim-at: calc(var(--intro-glow-at) - 0.2s);
      }

      /* Phase 1 — the whole navbar fades in first (before any glow). */
      :global(html[data-home-intro] .site-header) {
        animation: introNavFadeIn var(--intro-nav-fade, 0.45s) ease-out both;
      }
      @keyframes introNavFadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      /* Phase 2 — neon flicker on the navbar, starting AFTER the fade-in. Most
         elements' resting state has no glow, so their flicker fades to none at
         100%. The flicker portion is stepped; the fade-out tail is linear. */
      /* The logo glow filters live on each color layer's <svg> element (not the
         inner paths) so Safari renders them — see Header.astro. */
      :global(html[data-home-intro] .site-header .brand-layer-primary svg) {
        animation: introLogoPrimaryGlow var(--intro-glow-dur, 1.1s) linear
          var(--intro-glow-at, 0.45s) both;
      }
      :global(html[data-home-intro] .site-header .brand-layer-secondary svg) {
        animation: introLogoSecondaryGlow var(--intro-glow-dur, 1.1s) linear
          var(--intro-glow-at, 0.45s) both;
      }
      /* Nav links flicker in like a row of old neon signs igniting at RANDOM
         times — not in unison. Each link shares the introTextGlow keyframe but
         gets its own start delay AND a slightly different duration, so their
         stutter pulses fall at different moments and desync. All still finish
         within Phase 2 (delays are small, durations ≤ base) so the handoff to the
         resting state stays clean. --gd is the base Phase-2 flicker duration. */
      :global(html[data-home-intro] .internal-links a) {
        --gd: var(--intro-glow-dur, 1.1s);
        animation: introTextGlow var(--gd) linear var(--intro-glow-at, 0.45s)
          both;
      }
      /* Per-link offsets (hand-picked to look scattered, not sequential). The
         delay adds onto --intro-glow-at; the duration tweak shifts the rhythm. */
      :global(html[data-home-intro] .internal-links a:nth-child(1)) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0.12s);
        animation-duration: calc(var(--gd) * 0.86);
      }
      :global(html[data-home-intro] .internal-links a:nth-child(2)) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0.4s);
        animation-duration: calc(var(--gd) * 0.78);
      }
      :global(html[data-home-intro] .internal-links a:nth-child(3)) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0s);
        animation-duration: calc(var(--gd) * 0.92);
      }
      :global(html[data-home-intro] .internal-links a:nth-child(4)) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0.52s);
        animation-duration: calc(var(--gd) * 0.74);
      }
      :global(html[data-home-intro] .internal-links a:nth-child(5)) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0.26s);
        animation-duration: calc(var(--gd) * 0.83);
      }
      /* The magicbar's RESTING state already glows, so its intro flicker must end
         IN the glowing state (not fade to none) for a seamless handoff. */
      :global(html[data-home-intro] .nav-underline) {
        animation: introUnderlineGlow var(--intro-glow-dur, 1.1s) linear
          var(--intro-glow-at, 0.45s) both;
      }
      /* Right-side action icons also ignite at RANDOM times (not in unison),
         like the nav links. Each action item's icon gets its own delay + a
         slightly different duration so their flickers desync. */
      :global(html[data-home-intro] .header-actions svg),
      :global(html[data-home-intro] #menu-toggle svg) {
        --gd: var(--intro-glow-dur, 1.1s);
        animation: introIconGlow var(--gd) linear var(--intro-glow-at, 0.45s)
          both;
      }
      :global(html[data-home-intro] .header-actions > *:nth-child(1) svg) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0.34s);
        animation-duration: calc(var(--gd) * 0.8);
      }
      :global(html[data-home-intro] .header-actions > *:nth-child(2) svg) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0.06s);
        animation-duration: calc(var(--gd) * 0.9);
      }
      :global(html[data-home-intro] .header-actions > *:nth-child(3) svg) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0.48s);
        animation-duration: calc(var(--gd) * 0.72);
      }
      :global(html[data-home-intro] .header-actions > *:nth-child(4) svg) {
        animation-delay: calc(var(--intro-glow-at, 0.45s) + 0.2s);
        animation-duration: calc(var(--gd) * 0.85);
      }

      /* Phase 3 — simulation gas fades in (uniform, no flicker); the NAME
         activation flicker is driven in HeroSim. Starts at --intro-sim-at, which
         is independent of Phase 2 and may overlap it. */
      :global(html[data-home-intro] .hero-sim-grid) {
        animation: introGridFade var(--intro-sim-dur, 0.45s) ease-out
          var(--intro-sim-at, 2.1s) both;
      }
      :global(html[data-home-intro] .hero-sim-canvas) {
        animation: introCanvasFade var(--intro-sim-dur, 0.45s) ease-out
          calc(var(--intro-sim-at, 2.1s) + 0.02s) both;
      }
      /* Header + sim layers fade in on the scripted intro timeline. The card
         layer is NOT here on purpose: it's a scroll-progress crossfade (its own
         opacity clamp is 0 at the top and reveals on scroll), so holding it at
         opacity:0 during the intro would fight that and leave it stuck visible
         when scrolling back up. Letting it follow scroll progress gives the
         correct behavior both during and after the intro. */
      :global(html[data-home-intro] .site-header),
      :global(html[data-home-intro] .hero-sim-grid),
      :global(html[data-home-intro] .hero-sim-canvas) {
        opacity: 0;
      }
      /* True below-the-fold content (no scroll-progress opacity of its own) is
         held hidden during the intro so it doesn't pop in early. */
      :global(html[data-home-intro] .grid-2),
      :global(html[data-home-intro] main > hr) {
        opacity: 0;
      }
      /* If the user scrolls past the hero mid-intro (the scroll lock breaks),
         reveal that below-the-fold content so they don't land on a blank page.
         The card and sim are untouched here — they follow scroll progress / the
         scripted timeline respectively. */
      :global(html[data-home-intro][data-intro-scrolled] .grid-2),
      :global(html[data-home-intro][data-intro-scrolled] main > hr) {
        opacity: 1;
        transition: opacity 0.3s ease-out;
      }
      /* Final beat of the intro: the "scroll" cue fades in once the name has
         finished igniting (sim start + the activation flicker length), so it
         appears last and concludes the sequence instead of snapping in. */
      /* The scroll cue is the final beat of the intro. It's held hidden during
         the intro and faded in via a CSS TRANSITION (not a delayed keyframe —
         compositor-run keyframe opacity was rendering as a snap on this layer).
         JS adds .cue-in at the right moment to trigger the transition. */
      :global(html[data-home-intro] .hero-scroll-cue) {
        opacity: 0;
        transition: opacity 0.6s ease-out;
      }
      :global(html[data-home-intro] .hero-scroll-cue.cue-in) {
        opacity: 1;
      }
      /* Each glow flickers like a neon tube warming up: four quick stepped
         pulses (tight adjacent-% pairs read as instant on/off even under linear
         timing) through ~40%, then a SHORT sustained "on" (41–62%), then a smooth
         ramp DOWN to none by 100% so the glow fades out instead of snapping off.
         Off frames: 0–8, 12–15, 19–22, 26–30, 35–40. On frames: 9–11, 16–18,
         23–25, 31–34, 41–62. */
      @keyframes introLogoPrimaryGlow {
        0%,
        8%,
        12%,
        15%,
        19%,
        22%,
        26%,
        30%,
        35%,
        40% {
          filter: none;
        }
        9%,
        11%,
        16%,
        18%,
        23%,
        25%,
        31%,
        34%,
        41%,
        62% {
          filter: drop-shadow(0 0 6px var(--brand-glow-primary))
            drop-shadow(0 0 16px var(--brand-glow-primary));
        }
        /* Fade-out tail: drop most of the glow EARLY (by ~78%) so the final
           stretch is already near-zero and trails gently to nothing — avoids the
           abrupt cut you get when it stays bright until the very end. */
        72% {
          filter: drop-shadow(0 0 3px var(--brand-glow-primary))
            drop-shadow(0 0 8px var(--brand-glow-primary));
        }
        82% {
          filter: drop-shadow(0 0 1px var(--brand-glow-primary))
            drop-shadow(0 0 3px var(--brand-glow-primary));
        }
        100% {
          filter: drop-shadow(0 0 0 transparent) drop-shadow(0 0 0 transparent);
        }
      }
      @keyframes introLogoSecondaryGlow {
        0%,
        8%,
        12%,
        15%,
        19%,
        22%,
        26%,
        30%,
        35%,
        40% {
          filter: none;
        }
        9%,
        11%,
        16%,
        18%,
        23%,
        25%,
        31%,
        34%,
        41%,
        62% {
          filter: drop-shadow(0 0 6px var(--brand-glow-secondary))
            drop-shadow(0 0 16px var(--brand-glow-secondary));
        }
        72% {
          filter: drop-shadow(0 0 3px var(--brand-glow-secondary))
            drop-shadow(0 0 8px var(--brand-glow-secondary));
        }
        82% {
          filter: drop-shadow(0 0 1px var(--brand-glow-secondary))
            drop-shadow(0 0 3px var(--brand-glow-secondary));
        }
        100% {
          filter: drop-shadow(0 0 0 transparent) drop-shadow(0 0 0 transparent);
        }
      }
      @keyframes introTextGlow {
        0%,
        8%,
        12%,
        15%,
        19%,
        22%,
        26%,
        30%,
        35%,
        40% {
          text-shadow: none;
        }
        9%,
        11%,
        16%,
        18%,
        23%,
        25%,
        31%,
        34%,
        41%,
        62% {
          text-shadow:
            0 0 6px var(--nav-glow, var(--color-accent)),
            0 0 14px var(--nav-glow, var(--color-accent));
        }
        72% {
          text-shadow:
            0 0 3px var(--nav-glow, var(--color-accent)),
            0 0 7px var(--nav-glow, var(--color-accent));
        }
        82% {
          text-shadow:
            0 0 1px var(--nav-glow, var(--color-accent)),
            0 0 3px var(--nav-glow, var(--color-accent));
        }
        100% {
          text-shadow:
            0 0 0 transparent,
            0 0 0 transparent;
        }
      }
      @keyframes introIconGlow {
        0%,
        8%,
        12%,
        15%,
        19%,
        22%,
        26%,
        30%,
        35%,
        40% {
          filter: none;
        }
        9%,
        11%,
        16%,
        18%,
        23%,
        25%,
        31%,
        34%,
        41%,
        62% {
          filter: drop-shadow(0 0 5px var(--nav-glow, var(--color-accent)))
            drop-shadow(0 0 12px var(--nav-glow, var(--color-accent)));
        }
        72% {
          filter: drop-shadow(0 0 2px var(--nav-glow, var(--color-accent)))
            drop-shadow(0 0 6px var(--nav-glow, var(--color-accent)));
        }
        82% {
          filter: drop-shadow(0 0 1px var(--nav-glow, var(--color-accent)))
            drop-shadow(0 0 2px var(--nav-glow, var(--color-accent)));
        }
        100% {
          filter: drop-shadow(0 0 0 transparent) drop-shadow(0 0 0 transparent);
        }
      }
      @keyframes introUnderlineGlow {
        0%,
        8%,
        12%,
        15%,
        19%,
        22%,
        26%,
        30%,
        35%,
        40% {
          box-shadow: none;
        }
        9%,
        11%,
        16%,
        18%,
        23%,
        25%,
        31%,
        34%,
        41%,
        100% {
          /* Hold the glow all the way to 100% — the magicbar's resting state
             glows, so ending lit makes the handoff seamless (no fade-out). */
          box-shadow:
            0 0 6px var(--nav-glow, var(--color-accent)),
            0 0 12px var(--nav-glow, var(--color-accent));
        }
      }
      @keyframes introGridFade {
        from {
          opacity: 0;
        }
        to {
          opacity: 0.24;
        }
      }
      /* The canvas fades in UNIFORMLY (the whole gas appears at one ambient
         color, name not yet visible). The neon "activation" flicker — the
         inside-name particles igniting their color+glow — is driven inside the
         simulation's render loop (HeroSim.astro: activatedIntroAlpha), NOT here,
         so only the activation flickers, never the gas as a whole. */
      @keyframes introCanvasFade {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      .home-main {
        /* Remove the global top padding on the homepage so the pinned hero starts
           immediately below the header and scroll progress begins on first input. */
        padding-top: 0;
      }
      .hero-stage {
        position: sticky;
        top: var(--header-h);
        height: calc(100svh - var(--header-h));
        display: grid; /* stack the two layers in one cell */
      }
      .hero-layer {
        grid-area: 1 / 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      /* --- Sim layer: visible at progress 0, fully faded by ~0.5 (so by the
         snap midpoint the swap is essentially done and the snap lands clean) --- */
      .hero-layer-sim {
        position: relative;
        align-items: center;
        opacity: clamp(0, calc(1 - var(--hero-progress) / 0.5), 1);
        /* Drift up & away slightly as it fades so the swap has motion. */
        transform: translateY(calc(var(--hero-progress) * -4vh));
        /* Once mostly faded, stop intercepting the pointer so the card's links
           and the page below are interactive. */
        pointer-events: auto;
      }
      .hero-layer-sim > :global(.hero-sim) {
        flex: 0 1 auto;
        width: 100%;
        height: min(100%, 44rem);
        min-height: 14rem;
        max-height: 44rem;
      }

      .hero-scroll-cue {
        position: absolute;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-text-muted);
        /* Fades as soon as the user starts scrolling. */
        opacity: clamp(0, calc(1 - var(--hero-progress) / 0.15), 1);
        animation: heroCueBob 1.8s ease-in-out infinite;
        pointer-events: none;
      }
      @keyframes heroCueBob {
        0%,
        100% {
          translate: 0 0;
        }
        50% {
          translate: 0 4px;
        }
      }

      /* --- Card layer: hidden until ~0.4, fully in by ~0.85 (slightly trails
         the sim so they briefly overlap instead of flashing empty bg) --- */
      .hero-layer-card {
        opacity: clamp(0, calc((var(--hero-progress) - 0.4) / 0.45), 1);
        transform: translateY(calc((1 - var(--hero-progress)) * 5vh));
        /* Not interactive until it's substantially visible (set by JS toggling
           the data-hero-active attribute below). */
        pointer-events: none;
      }
      .hero-scroll[data-hero-active="card"] .hero-layer-card {
        pointer-events: auto;
      }
      .hero-scroll[data-hero-active="card"] .hero-layer-sim {
        pointer-events: none;
      }

      .hero-card {
        display: flex;
        align-items: center;
        gap: 3.5rem;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1rem;
        width: 100%;
      }
      .hero-portrait {
        flex: 0 0 auto;
      }
      .hero-portrait img {
        display: block;
        width: 240px;
        height: 240px;
        object-fit: cover;
        border-radius: 50%;
        border: 6px solid var(--color-bg);
        box-shadow:
          0 0 0 1px var(--color-border),
          0 12px 28px rgba(0, 0, 0, 0.4);
      }
      .hero-copy {
        flex: 1 1 auto;
      }
      .hero-copy h1 {
        font-size: 3rem;
        margin: 0 0 0.4rem;
        line-height: 1.05;
      }
      .hero-role {
        color: var(--color-accent);
        font-family: var(--font-sans);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.95rem;
        font-weight: 600;
        margin: 0 0 1.25rem;
      }
      .hero-bio {
        font-size: 1.05rem;
        line-height: 1.6;
        margin: 0 0 1.75rem;
      }
      .hero-buttons {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .pub-mini-item {
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
      }
      .pub-mini-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
      }
      .pub-title {
        font-weight: 700;
        color: var(--color-text-main);
        display: block;
        margin-bottom: 0.25rem;
        font-family: var(--font-serif);
        font-size: 1.1rem;
      }
      .pub-meta {
        font-size: 0.9rem;
        color: var(--color-text-muted);
      }

      /* --- Mobile: drop the pinned scrub. Sticky pinning + the sim's
         overflow-x clipping fight each other on touch, and a scrub feels worse
         than a simple stack on a phone. Show the sim (one screen) then the card
         stacked below; both always visible, no crossfade. --- */
      @media (max-width: 768px) {
        .hero-scroll {
          height: auto;
          overflow-x: clip;
        }
        .hero-stage {
          position: static;
          height: auto;
          display: flex;
          flex-direction: column;
          gap: 2rem;
        }
        .hero-layer {
          /* Cancel all scrub-driven transforms/opacity. */
          opacity: 1 !important;
          transform: none !important;
          pointer-events: auto !important;
        }
        /* On desktop the card is hidden at scroll-top by its scroll-progress
           opacity clamp, so it never shows during the intro. Mobile stacks the
           layers and forces .hero-layer opacity to 1 (above), which would reveal
           the card — and its headshot — on landing, flashing it before the sim
           fades in. Hold the card hidden during the intro so only the simulation
           is visible on arrival; it follows the sim's fade-in timing. After the
           intro clears (data-home-intro removed) the card shows normally. */
        :global(html[data-home-intro]) .hero-layer-card {
          animation: introCanvasFade var(--intro-sim-dur, 0.45s) ease-out
            calc(var(--intro-sim-at, 2.1s) + 0.04s) both;
        }
        .hero-layer-sim {
          /* Fill the entire first screen below the header so the simulation is
             the ONLY thing visible on landing — the card (and its headshot, plus
             the stage's row gap) all sit fully below the fold. Use `lvh` (LARGE
             viewport): on iOS the toolbars are expanded on landing, so `svh`
             would leave the sim shorter than the visible screen and the headshot
             would peek at the bottom. `lvh` sizes to the toolbars-hidden height,
             guaranteeing the sim covers the initial view with no resize jitter. */
          height: calc(100lvh - var(--header-h));
          min-height: calc(100lvh - var(--header-h));
        }
        .hero-layer-sim > :global(.hero-sim) {
          flex: 1 1 auto;
          height: 100%;
          max-height: none;
        }
        .hero-scroll-cue {
          display: none;
        }
        .hero-card {
          flex-direction: column;
          text-align: center;
          gap: 1.5rem;
        }
        .hero-portrait img {
          width: 200px;
          height: 200px;
        }
        .hero-buttons {
          justify-content: center;
        }
        .hero-copy h1 {
          font-size: 2.25rem;
        }
      }

      /* --- Scroll reveal: the below-hero content (Selected Research, Latest
         Posts) starts slightly down + transparent and eases in when scrolled into
         view (JS adds .is-revealed via IntersectionObserver). --reveal-delay
         staggers the two columns. --- */
      [data-reveal] {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 0.6s ease-out var(--reveal-delay, 0s),
          transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0s);
        will-change: opacity, transform;
      }
      [data-reveal].is-revealed {
        opacity: 1;
        transform: none;
      }

      /* --- Reduced motion: no pin, no crossfade — just stack the two views, and
         no reveal animation (content is shown immediately). --- */
      @media (prefers-reduced-motion: reduce) {
        .hero-scroll {
          height: auto;
        }
        .hero-stage {
          position: static;
          height: auto;
          display: flex;
          flex-direction: column;
          gap: 2rem;
        }
        .hero-layer {
          opacity: 1 !important;
          transform: none !important;
          pointer-events: auto !important;
        }
        .hero-layer-sim {
          /* Fill the first screen so the headshot stays below the fold even when
             the scripted intro is skipped (reduced-motion sets no data-home-intro,
             so the intro card-hide never runs — this layout must stand alone).
             `lvh` for the same iOS toolbar reason as the mobile block above. */
          height: calc(100lvh - var(--header-h));
          min-height: calc(100lvh - var(--header-h));
        }
        .hero-scroll-cue {
          display: none;
        }
        [data-reveal] {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="home-main" transition:animate={pageFade}>
      {
        /* Pinned-scrub hero: on landing the visitor sees ONLY the full-screen
          simulation. Scrolling through the tall .hero-scroll spacer keeps the
          .hero-stage pinned (sticky) and crossfades the sim out as the
          two-column "card" (portrait + name + bio + CTAs) fades in — only one
          view is visible at a time. JS sets --hero-progress (0→1) from scroll;
          CSS maps it to the two layers' opacity/transform. Reduced-motion and
          mobile fall back to a simple stacked layout (see <style>). */
      }
      <section class="hero-scroll" data-hero-scroll>
        <div class="hero-stage">
          <div class="hero-layer hero-layer-sim" data-hero-sim-layer>
            <HeroSim />
            <div class="hero-scroll-cue" aria-hidden="true">
              <span>scroll</span>
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 5v14M19 12l-7 7-7-7"></path></svg
              >
            </div>
          </div>

          <div class="hero-layer hero-layer-card" data-hero-card>
            <div class="hero-card">
              <div class="hero-portrait">
                <img
                  src={url("/about/profile.jpeg")}
                  width={260}
                  height={260}
                  alt="Sergio Eraso"
                  decoding="async"
                />
              </div>
              <div class="hero-copy">
                <h1>Sergio Eraso</h1>
                <p class="hero-role">PhD Candidate in Physics · MIT</p>
                <p class="hero-bio">
                  I work on <strong
                    >nonequilibrium statistical physics and biophysics</strong
                  > — finding the simple local rules that add up to complex collective
                  behavior, and building the models, simulations, and tools to actually
                  run them.
                </p>
                <div class="hero-buttons">
                  <a href={url("/publications")} class="btn">View Research</a>
                  <a href={url("/about")} class="btn btn-outline">About</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <hr style="margin: 3rem 0; border-top: 1px solid var(--color-border);" />

      <div class="grid-2" style="gap: 4rem; margin-top: 0;">
        <section data-reveal>
          <h2 style="margin-top: 0;">Selected Research</h2>
          <div class="publication-list">
            {
              selectedResearch.length > 0 ? (
                selectedResearch.map((entry) => (
                  <div class="pub-mini-item">
                    <a
                      class="pub-title"
                      href={url(`/publications/${entry.id}/`)}
                      style="display: block;"
                    >
                      {entry.data.title}
                    </a>
                    <div class="pub-meta">
                      <span style="font-style: italic; color: var(--color-accent);">
                        {entry.data.venue || "In preparation"}
                      </span>
                      <span>, {entry.data.date.getUTCFullYear()}</span>
                    </div>
                  </div>
                ))
              ) : (
                <p>No research entries yet.</p>
              )
            }
          </div>
          <div style="margin-top: 1.5rem;">
            <a href={url("/publications")} style="font-weight: 600;"
              >View all research &rarr;</a
            >
          </div>
        </section>

        <section data-reveal style="--reveal-delay: 0.08s;">
          <h2 style="margin-top: 0;">Latest Posts</h2>
          <ul style="list-style: none; padding: 0;">
            {
              posts.map((post) => (
                <li style="margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px dashed var(--color-border);">
                  <a
                    href={url(`/blog/${post.id}/`)}
                    style="display: block; font-family: var(--font-serif); font-size: 1.1rem; font-weight: 600; color: var(--color-text-main); margin-bottom: 0.25rem;"
                  >
                    {post.data.title}
                  </a>
                  <small style="color: var(--color-text-muted); text-transform: uppercase; font-size: 0.8rem;">
                    {post.data.pubDate.toLocaleDateString("en-us", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                      timeZone: "UTC",
                    })}
                  </small>
                </li>
              ))
            }
          </ul>
          <a href={url("/blog")} style="font-weight: 600;">View Blog &rarr;</a>
        </section>
      </div>
    </main>
    <Footer />

    <script is:inline>
      // Pinned-scrub progress. The .hero-scroll section is taller than the
      // viewport; while its top is above the header and its bottom is still
      // below, the .hero-stage is pinned. We map how far we've scrolled THROUGH
      // that extra distance to 0..1 and write it as --hero-progress, which the
      // CSS turns into the sim→card crossfade. data-hero-active flips to "card"
      // past the midpoint so only the active layer captures the pointer.
      function initHeroScroll() {
        const section = document.querySelector("[data-hero-scroll]");
        if (!section) return;
        if (section._heroScrollCleanup) section._heroScrollCleanup();

        const stage = section.querySelector(".hero-stage");
        const docEl = document.documentElement;
        const mqReduce = window.matchMedia("(prefers-reduced-motion: reduce)");
        const mqMobile = window.matchMedia("(max-width: 768px)");

        let raf = null;

        function isFallback() {
          return mqReduce.matches || mqMobile.matches;
        }

        // SNAP MODEL — JS settle on scroll-idle (NOT CSS scroll-snap).
        //
        // The crossfade is a free scrub: --hero-progress follows scrollY, so the
        // sim↔card swap scrubs smoothly in BOTH directions. To stop the page
        // resting half-faded we add the settle in JAVASCRIPT instead of CSS
        // scroll-snap. CSS snap was tried (mandatory, then proximity) and its
        // per-frame pull always fought the scrub: with a snap point at the very top
        // (sim) and one at the card it trapped you at the card scrolling up and at
        // the top scrolling down, and on Chrome the top-edge re-snap compounded with
        // the rubber-band into a runaway "scroll up forever" (the sticky header
        // drifting into mid-viewport). Firefox showed the pull as an abrupt teleport
        // past the fade. The JS settle below only fires AFTER scrolling stops, so it
        // never fights an in-progress gesture — no trap, no runaway.
        //
        // We ALSO keep `overscroll-behavior-y: none` while the hero is in view: it
        // contains the rubber-band at the document's top edge so a hard flick up
        // can't overscroll past scrollY 0 (belt-and-suspenders for the runaway).
        // Scoped to <html> only while you're at/near the hero; cleared once you've
        // scrolled to the content below (and in cleanup) so other pages — and
        // pull-to-refresh — behave normally.
        const GUARD_OFF_BELOW = 0.985; // scrolled past the hero → drop the guard
        let armed = false;

        function enableGuard(on) {
          if (on === armed) return;
          armed = on;
          docEl.style.overscrollBehaviorY = on ? "none" : "";
        }
        function setGuardForProgress(p) {
          if (isFallback()) {
            enableGuard(false);
            return;
          }
          enableGuard(p < GUARD_OFF_BELOW);
        }
        function applyGuard() {
          enableGuard(false);
          setGuardForProgress(progress());
        }

        // --- JS idle-settle ---------------------------------------------------
        // After scrolling stops inside the transition band, glide to the sim or
        // the card. The target is biased by the LAST scroll direction so a small
        // flick commits the way you were heading (instead of a hard 0.5 midpoint):
        //   scrolling DOWN → commit to the card, unless still right at the top
        //                    (p < FLICK) where a tiny nudge settles back to the sim
        //   scrolling UP   → commit to the sim, unless still right at the bottom
        //                    (p > 1-FLICK) where a tiny nudge settles back to the card
        // dir 0 (e.g. resize) falls back to the nearest endpoint by the midpoint.
        const SETTLE_IDLE_MS = 110; // quiet time after last scroll before settling
        const FLICK = 0.12; // dead-zone near an endpoint that resists the flick
        let settleTimer = null;
        let settling = false; // true while OUR programmatic glide is running
        let lastY = window.scrollY;
        let dir = 0; // +1 down, -1 up, 0 none

        function settleTarget(p) {
          if (dir > 0) return p < FLICK ? 0 : 1; // heading down → card
          if (dir < 0) return p > 1 - FLICK ? 1 : 0; // heading up → sim
          return p < 0.5 ? 0 : 1; // no direction → nearest
        }
        function doSettle() {
          settleTimer = null;
          if (isFallback() || settling) return;
          const p = progress();
          if (p <= 0.001 || p >= 0.999) return; // already on an endpoint
          const m = metrics();
          const targetY = settleTarget(p) === 0 ? m.start : m.start + m.travel;
          if (Math.abs(targetY - window.scrollY) < 1) return;
          settling = true;
          window.scrollTo({ top: targetY, behavior: "smooth" });
          // Clear the settling flag once we've effectively arrived (smooth scroll
          // has no completion event). Poll briefly; bail out if the user grabs the
          // scroll again (handled in onScroll, which cancels settling on real input).
          const startedAt = performance.now();
          const check = () => {
            if (!settling) return;
            if (
              Math.abs(window.scrollY - targetY) < 2 ||
              performance.now() - startedAt > 700
            ) {
              settling = false;
              return;
            }
            requestAnimationFrame(check);
          };
          requestAnimationFrame(check);
        }
        function scheduleSettle() {
          if (settleTimer != null) clearTimeout(settleTimer);
          settleTimer = window.setTimeout(doSettle, SETTLE_IDLE_MS);
        }

        function metrics() {
          const headerH =
            (stage && parseFloat(getComputedStyle(stage).top)) || 4.5 * 16;
          const pinned = window.innerHeight - headerH;
          const travel = Math.max(1, section.offsetHeight - pinned);
          const sectionTop =
            section.getBoundingClientRect().top + window.scrollY;
          const start = sectionTop - headerH;
          return { start, end: start + travel, travel };
        }
        function progress() {
          const m = metrics();
          return Math.min(
            1,
            Math.max(0, (window.scrollY - m.start) / m.travel),
          );
        }

        function update() {
          raf = null;
          // In the stacked fallbacks there's no scrub.
          if (isFallback()) {
            section.style.setProperty("--hero-progress", "0");
            section.removeAttribute("data-hero-active");
            return;
          }
          const p = progress();
          section.style.setProperty("--hero-progress", p.toFixed(4));
          section.setAttribute("data-hero-active", p > 0.5 ? "card" : "sim");
          setGuardForProgress(p);
        }
        function onScroll() {
          const y = window.scrollY;
          // Only REAL user scrolling cancels an in-flight settle and re-arms the
          // idle timer. Our own programmatic glide (settling) must not cancel
          // itself or it would never reach the endpoint.
          if (!settling) {
            if (y !== lastY) dir = y > lastY ? 1 : -1;
            if (!isFallback()) scheduleSettle();
          }
          lastY = y;
          if (raf == null) raf = requestAnimationFrame(update);
        }

        // Real input intent (wheel/touch/keyboard) ALWAYS interrupts an in-flight
        // settle so the user can grab the scroll back mid-glide — without this the
        // `settling` guard in onScroll would swallow their input until arrival.
        const cancelSettle = () => {
          if (settleTimer != null) {
            clearTimeout(settleTimer);
            settleTimer = null;
          }
          settling = false;
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll);
        window.addEventListener("wheel", cancelSettle, { passive: true });
        window.addEventListener("touchstart", cancelSettle, { passive: true });
        window.addEventListener("keydown", cancelSettle);
        const onMqChange = () => {
          applyGuard();
          update();
        };
        mqReduce.addEventListener("change", onMqChange);
        mqMobile.addEventListener("change", onMqChange);
        applyGuard();
        update();

        section._heroScrollCleanup = () => {
          window.removeEventListener("scroll", onScroll);
          window.removeEventListener("resize", onScroll);
          window.removeEventListener("wheel", cancelSettle);
          window.removeEventListener("touchstart", cancelSettle);
          window.removeEventListener("keydown", cancelSettle);
          mqReduce.removeEventListener("change", onMqChange);
          mqMobile.removeEventListener("change", onMqChange);
          if (raf != null) cancelAnimationFrame(raf);
          if (settleTimer != null) clearTimeout(settleTimer);
          settling = false;
          // Drop the page-scoped overscroll guard so other pages overscroll /
          // pull-to-refresh normally.
          enableGuard(false);
          delete section._heroScrollCleanup;
        };
      }

      initHeroScroll();
      document.addEventListener("astro:page-load", initHeroScroll);

      function initHomeIntro() {
        const root = document.documentElement;
        if (!root.hasAttribute("data-home-intro")) return;

        // Reveal the scroll cue (idempotent — re-adding the class is a no-op).
        const showCue = () =>
          root.querySelector(".hero-scroll-cue")?.classList.add("cue-in");

        // Block scrolling during the intro WITHOUT hiding overflow (which would
        // remove the scrollbar track and shift the layout when the intro ends).
        // We just pin the window to the top until the intro completes; the
        // scrollbar track stays visible the whole time (html { overflow-y:
        // scroll }), so there's no width change.
        const lockScroll = (e) => {
          if (window.scrollY !== 0) window.scrollTo(0, 0);
          if (e && e.cancelable) e.preventDefault();
        };
        window.scrollTo(0, 0);
        window.addEventListener("scroll", lockScroll, { passive: true });
        window.addEventListener("wheel", lockScroll, { passive: false });
        window.addEventListener("touchmove", lockScroll, { passive: false });
        let released = false;
        const releaseScrollLock = () => {
          if (released) return;
          released = true;
          window.removeEventListener("scroll", lockScroll);
          window.removeEventListener("wheel", lockScroll);
          window.removeEventListener("touchmove", lockScroll);
          window.removeEventListener("wheel", onScrollIntent);
          window.removeEventListener("touchstart", onScrollIntent);
          window.removeEventListener("keydown", onScrollIntent);
          window.__homeIntroReleaseScroll = null;
          // If they broke the lock before the cue appeared, show it now so the
          // page reads as intentionally scrollable.
          showCue();
        };
        // RESPONSIVENESS: the lock only exists to play the intro "from the top".
        // It is INDEPENDENT of the animation (CSS + the sim's RAF loop, both
        // driven by data-home-intro / the cue timer — none of which read
        // scrollY), so the moment the user actually tries to scroll we release
        // the lock and let them go; the intro keeps playing underneath, no
        // glitch. A short floor stops a stray load-time event from skipping it.
        // Without interaction, the timed release at the end still fires (below).
        const INTRO_SCROLL_FLOOR = 350; // ms before user intent can break the lock
        const introStart = performance.now();
        const SCROLL_KEYS = new Set([
          "ArrowDown",
          "ArrowUp",
          "PageDown",
          "PageUp",
          "End",
          "Home",
          " ",
        ]);
        const onScrollIntent = (e) => {
          // Ignore zoom/modifier gestures; only genuine scroll intent releases.
          if (e.type === "keydown" && !SCROLL_KEYS.has(e.key)) return;
          if (performance.now() - introStart < INTRO_SCROLL_FLOOR) return;
          // Force-reveal below-the-fold content (it's held at opacity:0 during
          // the intro) so scrolling away from the hero doesn't show a blank page.
          root.setAttribute("data-intro-scrolled", "");
          releaseScrollLock();
        };
        window.addEventListener("wheel", onScrollIntent, { passive: true });
        window.addEventListener("touchstart", onScrollIntent, {
          passive: true,
        });
        window.addEventListener("keydown", onScrollIntent);
        // If the user navigates AWAY mid-intro, release the lock so its window
        // listeners don't linger onto other pages.
        window.__homeIntroReleaseScroll = releaseScrollLock;

        // Hold the intro state until everything finishes. The phases can OVERLAP
        // now (the sim may start mid-flicker), so the end is the latest of:
        //   - Phase 2 nav flicker end   (nav-fade + glow)
        //   - sim CSS fade end          (--intro-sim-at + --intro-sim-dur)
        //   - sim activation flicker end(--intro-sim-at + ~1300ms)
        //   - scroll-cue fade-in end    (--intro-sim-at + 1.3s + 0.6s)
        const cs = getComputedStyle(root);
        const ms = (name, fallback) => {
          const raw = cs.getPropertyValue(name).trim();
          if (!raw) return fallback;
          const v = raw.endsWith("ms")
            ? parseFloat(raw)
            : parseFloat(raw) * 1000;
          return isFinite(v) ? v : fallback;
        };
        // Resolve --intro-sim-at (a calc()) the same way HeroSim does: read it
        // back as a browser-resolved animation-delay from a throwaway probe.
        const resolveSimAt = () => {
          try {
            const probe = document.createElement("div");
            probe.style.position = "absolute";
            probe.style.animationName = "introCanvasFade";
            probe.style.animationDuration = "1s";
            probe.style.animationDelay = "var(--intro-sim-at)";
            root.appendChild(probe);
            const r = getComputedStyle(probe).animationDelay;
            probe.remove();
            const v = r.endsWith("ms") ? parseFloat(r) : parseFloat(r) * 1000;
            return isFinite(v) ? v : 1750;
          } catch {
            return 1750;
          }
        };
        const navFlickerEnd =
          ms("--intro-nav-fade", 1100) + ms("--intro-glow-dur", 1300);
        const simAt = resolveSimAt();
        const cssEnd = Math.max(
          navFlickerEnd,
          simAt + ms("--intro-sim-dur", 700),
        );
        const activationEnd = simAt + 1300; // matches HeroSim activatedIntroAlpha end

        // Final beat: trigger the scroll-cue fade-in (CSS transition) once the
        // name has finished igniting.
        const CUE_AT = simAt + 600; // start of the cue fade (earlier: as the name ignites)
        const CUE_DUR = 600; // must match the CSS transition duration
        const cueEnd = CUE_AT + CUE_DUR;
        window.setTimeout(showCue, CUE_AT);

        window.setTimeout(
          () => {
            root.removeAttribute("data-home-intro");
            root.removeAttribute("data-intro-scrolled");
            releaseScrollLock();
          },
          Math.max(cssEnd, activationEnd, cueEnd) + 120,
        );
      }

      initHomeIntro();
      document.addEventListener("astro:page-load", initHomeIntro);
      document.addEventListener("astro:before-swap", () => {
        window.__homeIntroReleaseScroll?.();
      });

      // Scroll reveal for below-hero content. Reveal once when each [data-reveal]
      // scrolls into view; no un-reveal (so it doesn't flicker on scroll-up).
      function initReveal() {
        const items = document.querySelectorAll("[data-reveal]");
        if (!items.length) return;
        if (
          window.matchMedia("(prefers-reduced-motion: reduce)").matches ||
          !("IntersectionObserver" in window)
        ) {
          items.forEach((el) => el.classList.add("is-revealed"));
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-revealed");
                obs.unobserve(e.target);
              }
            }
          },
          // Trigger a bit before fully in view so it feels responsive.
          { rootMargin: "0px 0px -12% 0px", threshold: 0.05 },
        );
        items.forEach((el) => {
          el.classList.remove("is-revealed");
          io.observe(el);
        });
      }

      initReveal();
      document.addEventListener("astro:page-load", initReveal);
    </script>
  </body>
</html>
