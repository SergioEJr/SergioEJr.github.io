---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSim from "../components/HeroSim.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import { url } from "../utils/paths";
import { pageFade } from "../utils/pageTransition";
import { getPublishedPosts } from "../utils/posts";

const posts = (await getPublishedPosts())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allResearch = (await getCollection("research")).sort(
  (a, b) =>
    b.data.date.valueOf() - a.data.date.valueOf() || a.id.localeCompare(b.id),
);
const selectedResearch = (
  allResearch.filter((r) => r.data.selected).length > 0
    ? allResearch.filter((r) => r.data.selected)
    : allResearch
).slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      /* The hero fills exactly one viewport below the sticky header, so on
         landing the visitor sees only the simulation + description + buttons.
         svh (small viewport height) is stable on mobile — it doesn't jump when
         the browser URL bar shows/hides like vh does. --header-h matches the
         nav height in Header.astro. */
      .hero {
        --header-h: 4.5rem;
        min-height: calc(100svh - var(--header-h));
        padding: 1rem 0 1.25rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1.5rem;
        /* Desktop needs visible overflow so HeroSim's full-bleed canvas/grid can
           feather outside the text column. Mobile restores clipping below. */
        position: relative;
        overflow-x: visible;
      }
      /* The sim box takes the leftover vertical space; intro/buttons size to
         content. min-height keeps it usable on short screens. */
      .hero > :global(.hero-sim) {
        flex: 1 1 auto;
        min-height: 14rem;
      }
      .hero-intro {
        flex: 0 0 auto;
        max-width: 46rem;
        margin: 0 auto;
        text-align: center;
      }
      .hero-intro p {
        font-size: 1.05rem;
        line-height: 1.6;
        margin: 0 0 1.5rem;
      }
      .hero-role {
        color: var(--color-accent);
      }
      .hero-buttons {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .pub-mini-item {
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
      }
      .pub-mini-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
      }
      .pub-title {
        font-weight: 700;
        color: var(--color-text-main);
        display: block;
        margin-bottom: 0.25rem;
        font-family: var(--font-serif);
        font-size: 1.1rem;
      }
      .pub-meta {
        font-size: 0.9rem;
        color: var(--color-text-muted);
      }

      @media (min-width: 769px) {
        .hero > :global(.hero-sim) {
          /* Keep large monitors from diluting the fixed particle budget across
             an overly tall domain; roughly matches a 14-inch laptop feel. */
          max-height: 44rem;
        }
      }

      @media (max-width: 768px) {
        .hero {
          gap: 1.25rem;
          overflow-x: clip;
        }
        .hero-intro p {
          font-size: 0.95rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main transition:animate={pageFade}>
      <section class="hero">
        <HeroSim />
        <div class="hero-intro">
          <p>
            <strong class="hero-role"
              >PhD Student in Physics · MIT.</strong
            >
            I work on <strong
              >nonequilibrium statistical physics and biophysics</strong
            >, building models, simulations, and tools to understand how simple
            local rules produce predictable large-scale behavior in complex
            systems — and increasingly applying that toolkit beyond academia.
          </p>
          <div class="hero-buttons">
            <a href={url("/publications")} class="btn">View Research</a>
            <a href={url("/about")} class="btn btn-outline">About</a>
          </div>
        </div>
      </section>

      <hr style="margin: 3rem 0; border-top: 1px solid var(--color-border);" />

      <div class="grid-2" style="gap: 4rem; margin-top: 0;">
        <section>
          <h2 style="margin-top: 0;">Selected Research</h2>
          <div class="publication-list">
            {
              selectedResearch.length > 0 ? (
                selectedResearch.map((entry) => (
                  <div class="pub-mini-item">
                    <a
                      class="pub-title"
                      href={url(`/publications/${entry.id}/`)}
                      style="display: block;"
                    >
                      {entry.data.title}
                    </a>
                    <div class="pub-meta">
                      <span style="font-style: italic; color: var(--color-accent);">
                        {entry.data.venue || "In preparation"}
                      </span>
                      <span>, {entry.data.date.getUTCFullYear()}</span>
                    </div>
                  </div>
                ))
              ) : (
                <p>No research entries yet.</p>
              )
            }
          </div>
          <div style="margin-top: 1.5rem;">
            <a href={url("/publications")} style="font-weight: 600;"
              >View all research &rarr;</a
            >
          </div>
        </section>

        <section>
          <h2 style="margin-top: 0;">Latest Posts</h2>
          <ul style="list-style: none; padding: 0;">
            {
              posts.map((post) => (
                <li style="margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px dashed var(--color-border);">
                  <a
                    href={url(`/blog/${post.id}/`)}
                    style="display: block; font-family: var(--font-serif); font-size: 1.1rem; font-weight: 600; color: var(--color-text-main); margin-bottom: 0.25rem;"
                  >
                    {post.data.title}
                  </a>
                  <small style="color: var(--color-text-muted); text-transform: uppercase; font-size: 0.8rem;">
                    {post.data.pubDate.toLocaleDateString("en-us", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                      timeZone: "UTC",
                    })}
                  </small>
                </li>
              ))
            }
          </ul>
          <a href={url("/blog")} style="font-weight: 600;">View Blog &rarr;</a>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>
