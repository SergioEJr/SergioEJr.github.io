---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { url } from '../utils/paths';
import { pageFade } from '../utils/pageTransition';

const projects = (await getCollection('projects')).sort(
	(a, b) => (a.data.order - b.data.order) || (b.data.date.valueOf() - a.data.date.valueOf()),
);

// Filter config — colors match the Journal categories (Math purple / Physics green).
const CAT_COLORS: Record<string, string> = {
	Technical: '#8b5cf6',
	Teaching: '#10b981',
};
const FILTERS = ['Technical', 'Teaching'] as const;
const filterCounts: Record<string, number> = { Technical: 0, Teaching: 0 };
for (const p of projects) for (const c of p.data.categories) filterCounts[c] = (filterCounts[c] || 0) + 1;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="Research Projects" />
		<style>
			.projects-section {
				max-width: var(--max-width);
				margin: 0 auto;
			}
			.projects-hero {
				text-align: center;
				margin-bottom: 4rem;
				padding: 2rem 0;
			}
			.projects-hero h1 {
				font-family: var(--font-serif);
				font-size: 3.2rem;
				margin: 0 0 1rem 0;
				color: var(--color-text-main);
				letter-spacing: -0.02em;
				line-height: 1.2;
			}
			.projects-hero p {
				font-size: 1.15rem;
				color: var(--color-text-muted);
				max-width: 700px;
				margin: 0 auto;
				line-height: 1.7;
			}
			.projects-filters {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.6rem;
				margin-bottom: 3rem;
			}
			.proj-filter {
				background: transparent;
				border: 1px solid var(--color-border);
				color: var(--color-text-muted);
				padding: 0.4rem 1.1rem;
				border-radius: 999px;
				font-size: 0.8rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.proj-filter .proj-filter-count {
				opacity: 0.6;
				margin-left: 0.2rem;
				font-variant-numeric: tabular-nums;
			}
			.proj-filter:hover { color: var(--f-color); border-color: var(--f-color); }
			.proj-filter.active { color: #fff; background: var(--f-color); border-color: var(--f-color); }
			.proj-filter.active .proj-filter-count { opacity: 0.85; }
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 2.5rem;
				margin-bottom: 4rem;
			}
			.projects-empty {
				text-align: center;
				color: var(--color-text-muted);
				padding: 3rem 0 5rem;
			}
			.project-card {
				position: relative;
				display: flex;
				flex-direction: column;
				text-decoration: none;
				color: inherit;
				background-color: var(--color-bg-offset);
				border: 1px solid var(--color-border);
				border-radius: 16px;
				overflow: hidden;
				transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
			}
			/* Whole card clickable via the title's stretched link */
			.card-link { color: inherit; text-decoration: none; }
			.card-link::after {
				content: "";
				position: absolute;
				inset: 0;
				z-index: 1;
			}
			.project-footer {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				margin-top: auto;
			}
			/* Repo icon sits above the stretched link so it stays separately clickable */
			.repo-icon {
				position: relative;
				z-index: 2;
				display: inline-flex;
				color: var(--color-text-muted);
				transition: color 0.2s ease, transform 0.2s ease;
			}
			.repo-icon:hover { color: var(--color-accent); transform: translateY(-1px); }
			.project-card:hover {
				transform: translateY(-6px);
				box-shadow: var(--shadow-lg);
				border-color: var(--color-accent);
			}
			.project-image {
				position: relative;
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
			}
			.project-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.6s ease;
			}
			.project-card:hover .project-image img {
				transform: scale(1.05);
			}
			.project-image-badges {
				position: absolute;
				top: 1rem;
				left: 1rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				z-index: 10;
			}
			.project-image-badge {
				display: inline-flex;
				align-items: center;
				padding: 0.25rem 0.7rem;
				border-radius: 999px;
				font-size: 0.65rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--badge-color);
				border: 1px solid color-mix(in srgb, var(--badge-color) 60%, transparent);
				background: rgba(15, 23, 42, 0.55);
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
			}
			.project-badge {
				position: absolute;
				top: 1rem;
				right: 1rem;
				padding: 0.35rem 0.8rem;
				background-color: var(--color-bg-header);
				color: var(--color-text-main);
				font-size: 0.7rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				border-radius: 20px;
				backdrop-filter: blur(8px);
				box-shadow: 0 2px 8px rgba(0,0,0,0.1);
				z-index: 10;
			}
			.project-content-wrapper {
				display: flex;
				flex-direction: column;
				padding: 1.75rem;
				flex: 1;
			}
			.project-year {
				font-size: 0.75rem;
				color: var(--color-accent);
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 0.5rem;
			}
			.project-card h3 {
				font-family: var(--font-serif);
				font-size: 1.4rem;
				margin: 0 0 1rem 0;
				line-height: 1.3;
				color: var(--color-text-main);
			}
			.project-card h3 a {
				color: inherit;
				text-decoration: none;
			}
			.project-description {
				color: var(--color-text-muted);
				font-size: 0.95rem;
				line-height: 1.6;
				margin-bottom: 1.5rem;
				flex: 1;
			}
			.project-meta {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				margin-bottom: 1.25rem;
				flex-wrap: wrap;
				padding-top: 1rem;
				border-top: 1px solid var(--color-border);
			}
			.meta-label {
				font-weight: 600;
				color: var(--color-text-muted);
			}
			.author-names {
				color: var(--color-text-main);
				font-weight: 500;
			}
			.read-more {
				display: inline-flex;
				align-items: center;
				font-size: 0.9rem;
				color: var(--color-accent);
				text-decoration: none;
				font-weight: 600;
				transition: gap 0.2s ease;
				gap: 0.25rem;
			}
			.read-more:hover {
				gap: 0.5rem;
			}
			@media (max-width: 768px) {
				.projects-hero h1 { font-size: 2.5rem; }
				.projects-grid { gap: 2rem; }
				.project-content-wrapper { padding: 1.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="projects-section" transition:animate={pageFade}>
			<div class="projects-hero">
				<h1>Projects</h1>
				<p>Tools, teaching, and experiments I've built — most started as a problem I wanted solved or an idea I wanted to understand.</p>
			</div>

			<div class="projects-filters" id="projects-filters">
				{FILTERS.map((c) => (
					<button
						class="proj-filter"
						data-filter={c}
						style={`--f-color:${CAT_COLORS[c]}`}
					>
						{c} <span class="proj-filter-count">{filterCounts[c]}</span>
					</button>
				))}
			</div>

			<div class="projects-grid">
				{projects.length > 0 ? projects.map((project) => (
					<article class="project-card" data-categories={project.data.categories.join(',')}>
						<div class="project-image">
							<img
								src={project.data.image ? url(project.data.image) : url(`/projects/${project.id}.png`)}
								alt={project.data.title}
							/>
							{/* Custom thumbnails get the category pills overlaid; the generated
							    hero card already has them baked in. */}
							{project.data.image && (
								<div class="project-image-badges">
									{project.data.categories.map((c) => (
										<span class="project-image-badge" style={`--badge-color:${CAT_COLORS[c]}`}>{c}</span>
									))}
								</div>
							)}
							<span class="project-badge">{project.data.status}</span>
						</div>

						<div class="project-content-wrapper">
							<div class="project-header">
								<span class="project-year">{project.data.date.getFullYear()}</span>
								<h3><a class="card-link" href={url(`/projects/${project.id}/`)}>{project.data.title}</a></h3>
							</div>

							<p class="project-description">{project.data.description}</p>

							{project.data.tags.length > 0 && (
								<div class="project-meta">
									<span class="author-names">{project.data.tags.join(' · ')}</span>
								</div>
							)}

							<div class="project-footer">
								<span class="read-more">Read more &rarr;</span>
								{project.data.repo && (
									<a class="repo-icon" href={project.data.repo} target="_blank" rel="noopener noreferrer" aria-label="GitHub repository" title="GitHub repository">
										<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
									</a>
								)}
							</div>
						</div>
					</article>
				)) : (
                    <p>No projects yet. Add Markdown files in <code>src/content/projects/</code>.</p>
                )}
			</div>
			<p class="projects-empty" id="projects-empty" hidden>No projects match the selected filters.</p>
		</main>
		<Footer />

		<script is:inline>
			function initProjectFilters() {
				const bar = document.getElementById('projects-filters');
				if (!bar || bar.dataset.init === 'true') return;
				bar.dataset.init = 'true';

				const filters = Array.from(bar.querySelectorAll('.proj-filter'));
				const cards = Array.from(document.querySelectorAll('.project-card'));
				const empty = document.getElementById('projects-empty');
				const active = new Set();

				function apply() {
					let visible = 0;
					cards.forEach((card) => {
						const cats = (card.getAttribute('data-categories') || '')
							.split(',')
							.filter(Boolean);
						// No filter selected → show all; otherwise show if it matches any active filter.
						const show =
							active.size === 0 || cats.some((c) => active.has(c));
						card.style.display = show ? '' : 'none';
						if (show) visible++;
					});
					if (empty) empty.hidden = visible !== 0;
				}

				filters.forEach((btn) => {
					btn.addEventListener('click', () => {
						const f = btn.getAttribute('data-filter');
						if (active.has(f)) active.delete(f);
						else active.add(f);
						btn.classList.toggle('active', active.has(f));
						apply();
					});
				});
			}

			initProjectFilters();
			document.addEventListener('astro:page-load', initProjectFilters);
		</script>
	</body>
</html>
