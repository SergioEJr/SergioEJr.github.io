---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { PROJECT_CATEGORY_COLORS } from '../../utils/categories';
import { url } from '../../utils/paths';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content, headings } = await render(project);
const { title, description, date, repo, link, categories, articleImage } = project.data;

const categoryBadges = categories.map((c) => ({
	label: c,
	color: PROJECT_CATEGORY_COLORS[c] ?? 'var(--color-accent)',
}));
---

<BlogPost
	title={title}
	description={description}
	pubDate={date}
	id={project.id}
	headings={headings}
	toc={headings.length > 1}
	noHero={true}
	categoryBadges={categoryBadges}
>
	{articleImage && (
		<div class="project-article-image" slot="hero">
			<img src={url(articleImage)} alt={title} loading="eager" fetchpriority="high" decoding="async" />
		</div>
	)}
	{(repo || link) && (
		<p class="project-links">
			{link && (
				<a class="btn" href={link} target="_blank" rel="noopener noreferrer" data-umami-event="project-link" data-umami-event-title={title} data-umami-event-kind="visit">Visit ↗</a>
			)}
			{repo && (
				<a class="btn btn-outline" href={repo} target="_blank" rel="noopener noreferrer" data-umami-event="project-link" data-umami-event-title={title} data-umami-event-kind="code">Code ↗</a>
			)}
		</p>
	)}
	<Content />
</BlogPost>

<style>
	.project-links {
		display: flex;
		gap: 0.75rem;
		margin-bottom: 2rem;
	}
	.project-article-image {
		width: 100%;
		max-width: 1020px;
		margin: 0 auto;
		overflow: hidden;
		border-radius: 12px;
		box-shadow: var(--shadow-md);
	}
	.project-article-image img {
		display: block;
		width: 100%;
		height: auto;
	}
</style>
